<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SID Reference — Live from DeepSID</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#0C0C1A;--card-bg:#13132A;--border:#252550;--text:#D8D8F0;--dim:#6060A0;--cyan:#22CCDD;--amber:#FFB700;--green:#55DD88;--red:#FF5566;--tab:var(--cyan);--raster-op:1;--shadow-op:.3;--header-bg:rgba(12,12,26,.95);--track-bg:rgba(255,255,255,.04);}
:root[data-theme="light"]{--bg:#F5F5FA;--card-bg:#FFFFFF;--border:#D8D8EA;--text:#1A1A2E;--dim:#8888AA;--cyan:#0099AA;--amber:#B87700;--green:#1A9955;--red:#CC2244;--raster-op:.55;--shadow-op:.08;--header-bg:rgba(245,245,250,.92);--track-bg:rgba(0,0,0,.05);}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif;min-height:100vh;transition:background .2s,color .2s;}
.raster{height:7px;opacity:var(--raster-op);background:linear-gradient(to right,#000 0%,#9F4E44 6.25%,#6ABFC6 12.5%,#A057A3 18.75%,#5CAB5E 25%,#50459B 31.25%,#C9D487 37.5%,#A1683C 43.75%,#6D5412 50%,#CB7E75 56.25%,#626262 62.5%,#898989 68.75%,#9FE78E 75%,#6FC2CC 81.25%,#ABABAB 87.5%,#FFF 100%);}
.theme-toggle{position:fixed;top:14px;right:16px;z-index:200;background:var(--card-bg);border:1px solid var(--border);border-radius:99px;padding:.4rem .9rem;font-family:'Share Tech Mono',monospace;font-size:.68rem;color:var(--text);cursor:pointer;display:flex;align-items:center;gap:.4rem;transition:border-color .15s;}
.theme-toggle:hover{border-color:var(--tab);}
header{padding:2rem 2rem 1.75rem;text-align:center;border-bottom:1px solid var(--border);}
.chip-label{display:inline-flex;align-items:center;gap:.5rem;font-family:'IBM Plex Mono',monospace;font-size:.63rem;color:var(--dim);letter-spacing:.18em;text-transform:uppercase;border:1px solid var(--border);padding:.25rem .9rem;border-radius:99px;margin-bottom:1rem;}
.chip-label::before{content:'●';color:var(--cyan);animation:blink 1.1s step-end infinite;}
@keyframes blink{50%{opacity:0;}}
h1{font-family:'Share Tech Mono',monospace;font-size:clamp(1.8rem,4.5vw,3rem);letter-spacing:.1em;color:var(--text);text-shadow:0 0 40px rgba(34,204,221,var(--shadow-op));}
h1 em{color:var(--cyan);font-style:normal;}
.sub{color:var(--dim);font-size:.85rem;margin-top:.4rem;}
.pills{display:flex;justify-content:center;gap:1rem;margin-top:1.25rem;flex-wrap:wrap;}
.pill{font-family:'Share Tech Mono',monospace;font-size:.7rem;color:var(--dim);border:1px solid var(--border);padding:.3rem .85rem;border-radius:2px;}
.pill strong{color:var(--amber);}
.tabs-wrap{position:sticky;top:0;z-index:100;background:var(--header-bg);backdrop-filter:blur(8px);border-bottom:1px solid var(--border);}
.tabs{display:flex;overflow-x:auto;scrollbar-width:none;max-width:1400px;margin:0 auto;padding:0 1rem;}
.tabs::-webkit-scrollbar{display:none;}
.tab{flex-shrink:0;padding:.85rem 1rem;background:none;border:none;color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:.7rem;letter-spacing:.04em;cursor:pointer;position:relative;white-space:nowrap;transition:color .15s;}
.tab:hover{color:var(--text);}
.tab.on{color:var(--text);}
.tab.on::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--tab);}
.search-bar{max-width:1400px;margin:0 auto;padding:.85rem 2rem 0;display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;}
#search-input{flex:1;min-width:200px;background:var(--card-bg);border:1px solid var(--border);border-radius:4px;padding:.55rem .8rem;color:var(--text);font-family:'Inter',sans-serif;font-size:.85rem;outline:none;transition:border-color .15s;}
#search-input:focus{border-color:var(--tab);}
#search-input::placeholder{color:var(--dim);}
#search-count{font-family:'IBM Plex Mono',monospace;font-size:.65rem;color:var(--dim);white-space:nowrap;}
.rand-btn{font-family:'Share Tech Mono',monospace;font-size:.68rem;background:var(--card-bg);border:1px solid var(--border);color:var(--text);padding:.5rem .9rem;border-radius:4px;cursor:pointer;white-space:nowrap;transition:border-color .15s;}
.rand-btn:hover{border-color:var(--amber);}
.cat-header{max-width:1400px;margin:0 auto;padding:1.5rem 2rem .75rem;}
.cat-title{font-family:'Share Tech Mono',monospace;font-size:1.05rem;letter-spacing:.06em;color:var(--tab);}
.cat-desc{color:var(--dim);font-size:.82rem;margin-top:.3rem;}
.grid{max-width:1400px;margin:0 auto;padding:1rem 2rem 4rem;display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;}
@media(max-width:900px){.grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:580px){.grid{grid-template-columns:1fr;padding:1rem 1rem 3rem;}}
.card{background:var(--card-bg);border:1px solid var(--border);border-radius:3px;padding:1.1rem;display:flex;flex-direction:column;gap:.65rem;transition:border-color .2s;animation:fu .3s ease both;}
.card:hover{border-color:var(--tab);}
@keyframes fu{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:none;}}
.card-top{display:flex;align-items:flex-start;gap:.65rem;}
.thumb{width:2.5rem;height:2.5rem;border-radius:3px;object-fit:cover;border:1px solid var(--border);flex-shrink:0;}
.flag{font-size:1.3rem;width:2.5rem;height:2.5rem;border-radius:3px;background:var(--track-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.nb{flex:1;min-width:0;}
.mn{font-family:'Share Tech Mono',monospace;font-size:.92rem;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.mh{font-size:.72rem;color:var(--tab);margin-top:.1rem;font-style:italic;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.meta{display:flex;align-items:center;gap:.5rem;font-size:.72rem;color:var(--dim);flex-wrap:wrap;}
.dot{color:var(--border);}
.tags{display:flex;gap:.3rem;flex-wrap:wrap;}
.tag{font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:.05em;text-transform:uppercase;border:1px solid var(--border);color:var(--dim);padding:.1rem .45rem;border-radius:2px;}
.bio{font-size:.78rem;color:#8080B8;line-height:1.6;flex:1;}
.cfoot{display:flex;align-items:center;justify-content:space-between;padding-top:.55rem;border-top:1px solid var(--border);gap:.5rem;flex-wrap:wrap;}
.dslink{font-family:'Share Tech Mono',monospace;font-size:.62rem;color:var(--cyan);text-decoration:none;border:1px solid rgba(34,204,221,.25);padding:.22rem .6rem;border-radius:2px;transition:background .15s;}
.dslink:hover{background:rgba(34,204,221,.08);}
.cnote{font-family:'IBM Plex Mono',monospace;font-size:.62rem;color:var(--dim);}
.fw{max-width:1400px;margin:0 auto;padding:0 2rem 4rem;}
.bar-row{display:flex;align-items:center;gap:8px;margin-bottom:5px;}
.bar-label{font-family:'Share Tech Mono',monospace;font-size:.68rem;color:var(--text);min-width:200px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;}
.bar-track{flex:1;height:14px;background:var(--track-bg);border-radius:2px;overflow:hidden;}
.bar-fill{height:100%;border-radius:2px;}
.bar-num{font-family:'IBM Plex Mono',monospace;font-size:.65rem;color:var(--amber);min-width:36px;text-align:right;}
.mp-tbl{width:100%;border-collapse:collapse;}
.mp-tbl th{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--dim);padding:.4rem .8rem;border-bottom:1px solid var(--border);text-align:left;}
.mp-tbl td{padding:.5rem .8rem;border-bottom:1px solid rgba(37,37,80,.4);font-size:.76rem;vertical-align:top;}
.mp-tbl tr:hover td{background:rgba(34,204,221,.03);}
.mp-title{font-family:'Share Tech Mono',monospace;font-size:.78rem;color:var(--text);}
.mp-desc{font-size:.7rem;color:var(--dim);margin-top:.15rem;max-width:420px;}
.mp-links a{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--cyan);text-decoration:none;margin-right:.5rem;white-space:nowrap;}
.mp-links a:hover{text-decoration:underline;}
.gap-item{background:var(--card-bg);border:1px solid var(--border);border-left:3px solid var(--red);border-radius:3px;padding:.75rem 1rem;margin-bottom:.5rem;font-size:.8rem;}
.gap-type{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--red);text-transform:uppercase;letter-spacing:.06em;}
.empty-state{text-align:center;padding:4rem 2rem;color:var(--dim);grid-column:1/-1;}
.empty-state code{background:var(--card-bg);border:1px solid var(--border);padding:.2rem .5rem;border-radius:3px;}
.card.hl{outline:2px solid var(--amber);animation:hlpulse 1.6s ease-out 1;}
@keyframes hlpulse{0%{box-shadow:0 0 0 6px rgba(255,183,0,.35);}100%{box-shadow:0 0 0 0 rgba(255,183,0,0);}}
footer{border-top:1px solid var(--border);text-align:center;padding:1.75rem 2rem;font-family:'Share Tech Mono',monospace;font-size:.7rem;color:var(--dim);line-height:2;}
footer a{color:var(--cyan);text-decoration:none;}
footer a:hover{text-decoration:underline;}
@media print{
  .theme-toggle,.tabs-wrap,.search-bar,.rand-btn{display:none !important;}
  body{background:#fff !important;color:#000 !important;}
  .card{break-inside:avoid;border:1px solid #999 !important;background:#fff !important;}
  .mn,.bar-label{color:#000 !important;}
  .raster{display:none;}
  a{color:#000 !important;text-decoration:underline !important;}
}
</style>
</head>
<body>
<div class="raster"></div>
<button class="theme-toggle" id="theme-toggle" onclick="toggleTheme()">
  <span id="theme-icon">🌙</span><span id="theme-label">Dark</span>
</button>
<header>
  <div class="chip-label">SID CHIP · MOS 6581/8580 · LIVE FROM DEEPSID</div>
  <h1>SID <em>REFERENCE</em></h1>
  <p class="sub">Composers, players, and documentation gaps — fetched live from the DeepSID API</p>
  <div class="pills" id="pills"></div>
</header>
<div class="tabs-wrap"><div class="tabs" id="tabs"></div></div>
<div class="search-bar" id="search-bar">
  <input type="text" id="search-input" placeholder="Filter this tab…" oninput="applyFilter(this.value)">
  <span id="search-count"></span>
  <button class="rand-btn" onclick="randomComposer()">🎲 Random composer</button>
</div>
<div class="cat-header" id="cat-header">
  <div class="cat-title" id="cat-title"></div>
  <div class="cat-desc" id="cat-desc"></div>
</div>
<div class="grid" id="grid"></div>
<footer>
  <a href="https://www.hvsc.c64.org/" target="_blank">HVSC</a> · <a href="https://deepsid.chordian.net/" target="_blank">DeepSID</a> · <a href="https://csdb.dk/" target="_blank">CSDb</a><br>
  <span id="gen-time"></span>
</footer>

<script>
/*__SID_DATA_INJECTION_POINT__*/

// Fallback if build-html.js hasn't been run yet / no data cached
window.SID_DATA = window.SID_DATA || { generatedAt: null, composers: [], players: [], gaps: [] };

// ── THEME TOGGLE ──────────────────────────────────────────────────────────
function applyTheme(theme){
  document.documentElement.setAttribute('data-theme', theme);
  document.getElementById('theme-icon').textContent = theme==='light' ? '☀️' : '🌙';
  document.getElementById('theme-label').textContent = theme==='light' ? 'Light' : 'Dark';
  try{ localStorage.setItem('sid-ref-theme', theme); }catch(e){}
}
function toggleTheme(){
  const cur = document.documentElement.getAttribute('data-theme') || 'dark';
  applyTheme(cur==='light' ? 'dark' : 'light');
}
(function initTheme(){
  let saved=null;
  try{ saved = localStorage.getItem('sid-ref-theme'); }catch(e){}
  if(!saved){
    saved = (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) ? 'light' : 'dark';
  }
  applyTheme(saved);
})();

// ── COUNTRY FLAGS (cosmetic only — falls back to a globe if unmapped) ──────
const FLAGS = {
  'Australia':'🇦🇺','Austria':'🇦🇹','Belgium':'🇧🇪','Brazil':'🇧🇷','Canada':'🇨🇦',
  'Croatia':'🇭🇷','Czech Republic':'🇨🇿','Denmark':'🇩🇰','Estonia':'🇪🇪','Finland':'🇫🇮',
  'France':'🇫🇷','Germany':'🇩🇪','Greece':'🇬🇷','Hungary':'🇭🇺','Iceland':'🇮🇸',
  'Ireland':'🇮🇪','Italy':'🇮🇹','Japan':'🇯🇵','Latvia':'🇱🇻','Lithuania':'🇱🇹',
  'Netherlands':'🇳🇱','New Zealand':'🇳🇿','Norway':'🇳🇴','Poland':'🇵🇱','Portugal':'🇵🇹',
  'Russia':'🇷🇺','Slovakia':'🇸🇰','Slovenia':'🇸🇮','Spain':'🇪🇸','Sweden':'🇸🇪',
  'Switzerland':'🇨🇭','Ukraine':'🇺🇦','United Kingdom':'🇬🇧','England':'🇬🇧',
  'United States':'🇺🇸','USA':'🇺🇸'
};
function flagFor(country){ return FLAGS[(country||'').trim()] || '🌐'; }
function imgFallback(el, flag){
  const div = document.createElement('div');
  div.className = 'flag';
  div.textContent = flag;
  el.replaceWith(div);
}

// ── TABS ─────────────────────────────────────────────────────────────────
const TABS = [
  {id:'composers', label:'Composers',          desc:'Every composer fetched from DeepSID so far — profile bio, country, and HVSC file count.'},
  {id:'players',   label:'Players / Editors',  desc:'The full players/editors database DeepSID knows about, in one request.'},
  {id:'countries', label:'Countries',          desc:'Composer count by country, derived from fetched profile data.'},
  {id:'gaps',      label:'Documentation Gaps', desc:'Sparse fields flagged by find-gaps.js — candidates for reporting upstream.'}
];

let currentTab = 'composers';
let currentFilter = '';

function renderPills(){
  const d = window.SID_DATA;
  const gen = d.generatedAt ? new Date(d.generatedAt).toLocaleString() : null;
  document.getElementById('pills').innerHTML = `
    <span class="pill"><strong>${(d.composers||[]).length}</strong> composers cached</span>
    <span class="pill"><strong>${(d.players||[]).length}</strong> players/editors</span>
    <span class="pill"><strong>${(d.gaps||[]).length}</strong> known gaps</span>
    <span class="pill">Generated <strong>${gen || 'never'}</strong></span>`;
  document.getElementById('gen-time').textContent = gen
    ? `Data generated ${gen}`
    : 'No data yet — run npm run all (see README.md)';
}

function renderTabs(){
  document.getElementById('tabs').innerHTML = TABS.map(t =>
    `<button class="tab${t.id===currentTab?' on':''}" data-t="${t.id}" onclick="render('${t.id}')">${t.label}</button>`
  ).join('');
}

function emptyState(msg, cmd){
  return `<div class="empty-state">
    <p>${msg}</p>
    ${cmd ? `<p style="margin-top:.75rem"><code>${cmd}</code></p>` : ''}
  </div>`;
}

function applyFilter(v){ currentFilter = v.toLowerCase(); render(currentTab); }

function render(tab){
  currentTab = tab;
  renderTabs();
  const meta = TABS.find(t => t.id === tab);
  document.getElementById('cat-title').textContent = meta.label;
  document.getElementById('cat-desc').textContent = meta.desc;
  document.getElementById('search-input').placeholder = `Filter ${meta.label.toLowerCase()}…`;

  const grid = document.getElementById('grid');
  if (tab === 'composers') return renderComposers(grid);
  if (tab === 'players') return renderPlayers(grid);
  if (tab === 'countries') return renderCountries(grid);
  if (tab === 'gaps') return renderGaps(grid);
}

function fileList(c){
  return Array.isArray(c.folder)
    ? c.folder
    : Object.values(c.folder || {}).filter(v => v && typeof v === 'object' && v.name);
}

function cleanNotable(s){
  return (s || '').replace(/\[#\]/g, '');
}

function buildComposerCard(c){
  const p = c.profile || {};
  const files = fileList(c);
  const badge = p.thumbnail
    ? `<img class="thumb" src="${p.thumbnail}" alt="${c.name}" loading="lazy" onerror="imgFallback(this,'${flagFor(p.country)}')">`
    : `<div class="flag">${flagFor(p.country)}</div>`;
  const fullName = p.full_name && p.full_name !== c.name ? `<div class="mh">${p.full_name}</div>` : '';
  const tags = [p.focus2, p.affiliation]
    .filter(t => t && t !== 'NONE')
    .map(t => `<span class="tag">${t}</span>`).join('');
  const bio = cleanNotable(p.notable);
  const dsUrl = `https://deepsid.chordian.net/?file=${c.path}`;
  const csdbUrl = p.csdb_id ? `https://csdb.dk/scener/?id=${p.csdb_id}` : null;
  return `<div class="card" data-name="${c.name.toLowerCase()}">
    <div class="card-top">
      ${badge}
      <div class="nb"><div class="mn">${c.name}</div>${fullName}</div>
    </div>
    <div class="meta"><span>${flagFor(p.country)} ${p.country || 'Unknown'}</span><span class="dot">·</span><span>${p.active || '—'}</span></div>
    ${tags ? `<div class="tags">${tags}</div>` : ''}
    ${bio ? `<div class="bio">${bio}</div>` : ''}
    <div class="cfoot">
      <a class="dslink" href="${dsUrl}" target="_blank">▶ DeepSID</a>
      ${csdbUrl ? `<a class="dslink" href="${csdbUrl}" target="_blank">CSDb</a>` : ''}
      <span class="cnote">${files.length} SID${files.length===1?'':'s'}</span>
    </div>
  </div>`;
}

function renderComposers(grid){
  grid.style.gridTemplateColumns = '';
  let list = window.SID_DATA.composers || [];
  if (currentFilter) list = list.filter(c => c.name.toLowerCase().includes(currentFilter));
  document.getElementById('search-count').textContent = `${list.length} shown`;
  if (list.length === 0) {
    grid.innerHTML = emptyState('No composer data cached yet.', 'node scripts/fetch-composers.js');
    return;
  }
  grid.innerHTML = list.map(buildComposerCard).join('');
}

function renderPlayers(grid){
  grid.style.gridTemplateColumns = '1fr';
  let list = window.SID_DATA.players || [];
  if (currentFilter) list = list.filter(p => (p.title||'').toLowerCase().includes(currentFilter));
  document.getElementById('search-count').textContent = `${list.length} shown`;
  if (list.length === 0) {
    grid.innerHTML = emptyState('No player/editor data cached yet.', 'node scripts/fetch-players.js');
    return;
  }
  const rows = list.map(p => {
    const years = `${p.start_year || '?'}–${p.end_year || 'present'}`;
    const links = [
      p.site ? `<a href="${p.site}" target="_blank">Site</a>` : '',
      p.docs ? `<a href="${p.docs}" target="_blank">Docs</a>` : '',
      p.source_code ? `<a href="${p.source_code}" target="_blank">Source</a>` : ''
    ].filter(Boolean).join('');
    return `<tr>
      <td><div class="mp-title">${p.title || '(untitled)'}</div>${p.description ? `<div class="mp-desc">${p.description}</div>` : ''}</td>
      <td>${p.developer || '—'}</td>
      <td>${p.platform || '—'}</td>
      <td>${years}</td>
      <td class="mp-links">${links}</td>
    </tr>`;
  }).join('');
  grid.innerHTML = `<div class="fw"><table class="mp-tbl"><thead><tr><th>Title</th><th>Developer</th><th>Platform</th><th>Years</th><th>Links</th></tr></thead><tbody>${rows}</tbody></table></div>`;
}

function renderCountries(grid){
  grid.style.gridTemplateColumns = '1fr';
  const composers = window.SID_DATA.composers || [];
  const counts = {};
  composers.forEach(c => {
    const country = c.profile && c.profile.country;
    if (!country) return;
    counts[country] = (counts[country] || 0) + 1;
  });
  let entries = Object.entries(counts).sort((a,b) => b[1]-a[1]);
  if (currentFilter) entries = entries.filter(([name]) => name.toLowerCase().includes(currentFilter));
  document.getElementById('search-count').textContent = `${entries.length} countries`;
  if (entries.length === 0) {
    grid.innerHTML = emptyState('No composer profile data with country info cached yet.', 'node scripts/fetch-composers.js');
    return;
  }
  const max = entries[0][1];
  const bars = entries.map(([name, n]) => `<div class="bar-row">
    <span class="bar-label">${flagFor(name)} ${name}</span>
    <div class="bar-track"><div class="bar-fill" style="width:${(n/max*100).toFixed(1)}%;background:var(--cyan)"></div></div>
    <div class="bar-num">${n}</div>
  </div>`).join('');
  grid.innerHTML = `<div class="fw" style="padding-top:1.5rem">${bars}</div>`;
}

function renderGaps(grid){
  grid.style.gridTemplateColumns = '1fr';
  let list = window.SID_DATA.gaps || [];
  if (currentFilter) list = list.filter(g => JSON.stringify(g).toLowerCase().includes(currentFilter));
  document.getElementById('search-count').textContent = `${list.length} shown`;
  if (list.length === 0) {
    grid.innerHTML = emptyState('No gaps report cached yet.', 'node scripts/find-gaps.js');
    return;
  }
  const items = list.slice(0, 300).map(g => `<div class="gap-item">
    <div class="gap-type">${g.type}</div>
    <div>${g.composer || g.title || ''} ${g.file ? '— ' + g.file : ''} ${g.detail ? '— ' + g.detail : ''}</div>
  </div>`).join('');
  const more = list.length > 300 ? `<p style="color:var(--dim);font-size:.75rem;margin-top:.5rem">+${list.length-300} more — see docs/GAPS_REPORT.md</p>` : '';
  grid.innerHTML = `<div class="fw" style="padding-top:1.5rem">${items}${more}</div>`;
}

function randomComposer(){
  const list = window.SID_DATA.composers || [];
  if (!list.length) return;
  const pick = list[Math.floor(Math.random() * list.length)];
  if (currentTab !== 'composers' || currentFilter) {
    document.getElementById('search-input').value = '';
    currentFilter = '';
    render('composers');
  }
  requestAnimationFrame(() => {
    const el = document.querySelector(`.card[data-name="${CSS.escape(pick.name.toLowerCase())}"]`);
    if (!el) return;
    el.scrollIntoView({behavior:'smooth', block:'center'});
    el.classList.add('hl');
    setTimeout(() => el.classList.remove('hl'), 1700);
  });
}

renderPills();
render('composers');
</script>
</body>
</html>
