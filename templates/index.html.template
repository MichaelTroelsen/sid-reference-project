<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SID Reference — Live from DeepSID</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#0C0C1A;--card-bg:#13132A;--border:#252550;--text:#D8D8F0;--dim:#6060A0;--cyan:#22CCDD;--amber:#FFB700;--green:#55DD88;--red:#FF5566;--tab:var(--cyan);--raster-op:1;--shadow-op:.3;--header-bg:rgba(12,12,26,.95);--track-bg:rgba(255,255,255,.04);}
:root[data-theme="light"]{--bg:#F5F5FA;--card-bg:#FFFFFF;--border:#D8D8EA;--text:#1A1A2E;--dim:#8888AA;--cyan:#0099AA;--amber:#B87700;--green:#1A9955;--red:#CC2244;--raster-op:.55;--shadow-op:.08;--header-bg:rgba(245,245,250,.92);--track-bg:rgba(0,0,0,.05);}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif;min-height:100vh;transition:background .2s,color .2s;}
.raster{height:7px;opacity:var(--raster-op);background:linear-gradient(to right,#000 0%,#9F4E44 6.25%,#6ABFC6 12.5%,#A057A3 18.75%,#5CAB5E 25%,#50459B 31.25%,#C9D487 37.5%,#A1683C 43.75%,#6D5412 50%,#CB7E75 56.25%,#626262 62.5%,#898989 68.75%,#9FE78E 75%,#6FC2CC 81.25%,#ABABAB 87.5%,#FFF 100%);}
.theme-toggle{position:fixed;top:14px;right:16px;z-index:200;background:var(--card-bg);border:1px solid var(--border);border-radius:99px;padding:.4rem .9rem;font-family:'Share Tech Mono',monospace;font-size:.68rem;color:var(--text);cursor:pointer;display:flex;align-items:center;gap:.4rem;transition:border-color .15s;}
.theme-toggle:hover{border-color:var(--tab);}
header{padding:2rem 2rem 1.75rem;text-align:center;border-bottom:1px solid var(--border);}
.chip-label{display:inline-flex;align-items:center;gap:.5rem;font-family:'IBM Plex Mono',monospace;font-size:.63rem;color:var(--dim);letter-spacing:.18em;text-transform:uppercase;border:1px solid var(--border);padding:.25rem .9rem;border-radius:99px;margin-bottom:1rem;}
.chip-label::before{content:'●';color:var(--cyan);animation:blink 1.1s step-end infinite;}
@keyframes blink{50%{opacity:0;}}
h1{font-family:'Share Tech Mono',monospace;font-size:clamp(1.8rem,4.5vw,3rem);letter-spacing:.1em;color:var(--text);text-shadow:0 0 40px rgba(34,204,221,var(--shadow-op));}
h1 em{color:var(--cyan);font-style:normal;}
.sub{color:var(--dim);font-size:.85rem;margin-top:.4rem;}
.pills{display:flex;justify-content:center;gap:1rem;margin-top:1.25rem;flex-wrap:wrap;}
.pill{font-family:'Share Tech Mono',monospace;font-size:.7rem;color:var(--dim);border:1px solid var(--border);padding:.3rem .85rem;border-radius:2px;}
.pill strong{color:var(--amber);}
.tabs-wrap{position:sticky;top:0;z-index:100;background:var(--header-bg);backdrop-filter:blur(8px);border-bottom:1px solid var(--border);}
.tabs{display:flex;overflow-x:auto;scrollbar-width:none;max-width:1400px;margin:0 auto;padding:0 1rem;}
.tabs::-webkit-scrollbar{display:none;}
.tab{flex-shrink:0;padding:.85rem 1rem;background:none;border:none;color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:.7rem;letter-spacing:.04em;cursor:pointer;position:relative;white-space:nowrap;transition:color .15s;}
.tab:hover{color:var(--text);}
.tab.on{color:var(--text);}
.tab.on::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--tab);}
.search-bar{max-width:1400px;margin:0 auto;padding:.85rem 2rem 0;display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;}
#search-input{flex:1;min-width:200px;background:var(--card-bg);border:1px solid var(--border);border-radius:4px;padding:.55rem .8rem;color:var(--text);font-family:'Inter',sans-serif;font-size:.85rem;outline:none;transition:border-color .15s;}
#search-input:focus{border-color:var(--tab);}
#search-input::placeholder{color:var(--dim);}
#sort-select{background:var(--card-bg);border:1px solid var(--border);border-radius:4px;padding:.55rem .8rem;color:var(--text);font-family:'Inter',sans-serif;font-size:.85rem;outline:none;cursor:pointer;}
#sort-select:focus{border-color:var(--tab);}
#search-count{font-family:'IBM Plex Mono',monospace;font-size:.65rem;color:var(--dim);white-space:nowrap;}
.rand-btn{font-family:'Share Tech Mono',monospace;font-size:.68rem;background:var(--card-bg);border:1px solid var(--border);color:var(--text);padding:.5rem .9rem;border-radius:4px;cursor:pointer;white-space:nowrap;transition:border-color .15s;}
.rand-btn:hover{border-color:var(--amber);}
.cat-header{max-width:1400px;margin:0 auto;padding:1.5rem 2rem .75rem;}
.cat-title{font-family:'Share Tech Mono',monospace;font-size:1.05rem;letter-spacing:.06em;color:var(--tab);}
.cat-desc{color:var(--dim);font-size:.82rem;margin-top:.3rem;}
.grid{max-width:1400px;margin:0 auto;padding:1rem 2rem 4rem;display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;}
@media(max-width:900px){.grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:580px){.grid{grid-template-columns:1fr;padding:1rem 1rem 3rem;}}
.card{background:var(--card-bg);border:1px solid var(--border);border-radius:3px;padding:1.1rem;display:flex;flex-direction:column;gap:.65rem;transition:border-color .2s;animation:fu .3s ease both;}
.card:hover{border-color:var(--tab);}
@keyframes fu{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:none;}}
.card-top{display:flex;align-items:flex-start;gap:.65rem;}
.thumb{width:2.5rem;height:2.5rem;border-radius:3px;object-fit:cover;border:1px solid var(--border);flex-shrink:0;}
.flag{font-size:1.3rem;width:2.5rem;height:2.5rem;border-radius:3px;background:var(--track-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.nb{flex:1;min-width:0;}
.mn{font-family:'Share Tech Mono',monospace;font-size:.92rem;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.mh{font-size:.72rem;color:var(--tab);margin-top:.1rem;font-style:italic;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.meta{display:flex;align-items:center;gap:.5rem;font-size:.72rem;color:var(--dim);flex-wrap:wrap;}
.dot{color:var(--border);}
.tags{display:flex;gap:.3rem;flex-wrap:wrap;}
.tag{font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:.05em;text-transform:uppercase;border:1px solid var(--border);color:var(--dim);padding:.1rem .45rem;border-radius:2px;}
.bio{font-size:.78rem;color:#8080B8;line-height:1.6;flex:1;}
.cfoot{display:flex;align-items:center;justify-content:space-between;padding-top:.55rem;border-top:1px solid var(--border);gap:.5rem;flex-wrap:wrap;}
.dslink{font-family:'Share Tech Mono',monospace;font-size:.62rem;color:var(--cyan);text-decoration:none;border:1px solid rgba(34,204,221,.25);padding:.22rem .6rem;border-radius:2px;transition:background .15s;}
.dslink:hover{background:rgba(34,204,221,.08);}
.cnote{font-family:'IBM Plex Mono',monospace;font-size:.62rem;color:var(--dim);}
.cnote-btn{font-family:'IBM Plex Mono',monospace;font-size:.62rem;color:var(--dim);background:none;border:none;cursor:pointer;padding:0;}
.cnote-btn:hover{color:var(--tab);}
.tag.ok{color:var(--green);border-color:rgba(85,221,136,.3);}
.tag.warn{color:var(--red);border-color:rgba(255,85,102,.3);}
.file-list{width:100%;margin-top:.5rem;max-height:220px;overflow-y:auto;border-top:1px solid var(--border);padding-top:.4rem;}
.file-row{display:flex;align-items:center;justify-content:space-between;gap:.5rem;padding:.25rem 0;font-size:.7rem;}
.file-name{font-family:'Share Tech Mono',monospace;color:var(--text);text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;min-width:0;}
.file-name:hover{color:var(--cyan);}
.fw{max-width:1400px;margin:0 auto;padding:0 2rem 4rem;}
.bar-row{display:flex;align-items:center;gap:8px;margin-bottom:5px;}
.bar-label{font-family:'Share Tech Mono',monospace;font-size:.68rem;color:var(--text);min-width:200px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;}
.bar-track{flex:1;height:14px;background:var(--track-bg);border-radius:2px;overflow:hidden;}
.bar-fill{height:100%;border-radius:2px;}
.bar-num{font-family:'IBM Plex Mono',monospace;font-size:.65rem;color:var(--amber);min-width:36px;text-align:right;}
.mp-tbl{width:100%;border-collapse:collapse;}
.mp-tbl th{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--dim);padding:.4rem .8rem;border-bottom:1px solid var(--border);text-align:left;}
.mp-tbl td{padding:.5rem .8rem;border-bottom:1px solid rgba(37,37,80,.4);font-size:.76rem;vertical-align:top;}
.mp-tbl tr:hover td{background:rgba(34,204,221,.03);}
.mp-tbl th.sortable{cursor:pointer;user-select:none;white-space:nowrap;}
.mp-tbl th.sortable:hover{color:var(--tab);}
.mp-tbl th.sortable.on{color:var(--tab);}
/* Files tab: facet toolbar + collapsible per-composer groups */
.ftools{display:flex;align-items:center;gap:.9rem;flex-wrap:wrap;padding:.2rem 0 1rem;border-bottom:1px solid var(--border);margin-bottom:.7rem;}
.ffilter{font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:var(--dim);display:flex;align-items:center;gap:.4rem;}
.ffilter select{background:var(--card-bg);border:1px solid var(--border);border-radius:4px;padding:.32rem .5rem;color:var(--text);font-family:'Inter',sans-serif;font-size:.75rem;text-transform:none;letter-spacing:0;outline:none;cursor:pointer;max-width:230px;}
.ffilter select:focus{border-color:var(--tab);}
.ftools-count{margin-left:auto;font-family:'IBM Plex Mono',monospace;font-size:.62rem;color:var(--dim);white-space:nowrap;}
.fgrp{border:1px solid var(--border);border-radius:5px;margin-bottom:.4rem;overflow:hidden;}
.fgrp-h{display:flex;align-items:center;gap:.6rem;padding:.5rem .8rem;cursor:pointer;background:var(--card-bg);user-select:none;}
.fgrp-h:hover{background:rgba(34,204,221,.05);}
.fgrp-caret{color:var(--tab);font-size:.7rem;width:.8rem;flex:none;}
.fgrp-name{font-family:'Share Tech Mono',monospace;font-size:.82rem;color:var(--cyan);}
.fgrp-meta{font-family:'IBM Plex Mono',monospace;font-size:.62rem;color:var(--dim);}
.fgrp-jump{margin-left:auto;font-family:'IBM Plex Mono',monospace;font-size:.6rem;color:var(--dim);text-decoration:none;white-space:nowrap;}
.fgrp-jump:hover{color:var(--tab);}
.fgrp-body{overflow-x:auto;}
.ftbl td{vertical-align:top;}
.mp-title{font-family:'Share Tech Mono',monospace;font-size:.78rem;color:var(--text);}
.mp-desc{font-size:.7rem;color:var(--dim);margin-top:.15rem;max-width:420px;}
.mp-links a{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--cyan);text-decoration:none;margin-right:.5rem;white-space:nowrap;}
.mp-links a:hover{text-decoration:underline;}
.gap-item{background:var(--card-bg);border:1px solid var(--border);border-left:3px solid var(--red);border-radius:3px;padding:.75rem 1rem;margin-bottom:.5rem;font-size:.8rem;}
.gap-type{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--red);text-transform:uppercase;letter-spacing:.06em;}
.sl{font-family:'Share Tech Mono',monospace;font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--dim);margin:1.5rem 0 .65rem;}
.sn{font-size:.72rem;color:var(--dim);background:rgba(34,204,221,.04);border:1px solid rgba(34,204,221,.12);padding:.55rem .9rem;border-radius:3px;margin:.5rem 0 1.25rem;line-height:1.6;}
.sn code{background:var(--card-bg);border:1px solid var(--border);padding:.05rem .35rem;border-radius:2px;}
.empty-state{text-align:center;padding:4rem 2rem;color:var(--dim);grid-column:1/-1;}
.empty-state code{background:var(--card-bg);border:1px solid var(--border);padding:.2rem .5rem;border-radius:3px;}
.card.hl{outline:2px solid var(--amber);animation:hlpulse 1.6s ease-out 1;}
@keyframes hlpulse{0%{box-shadow:0 0 0 6px rgba(255,183,0,.35);}100%{box-shadow:0 0 0 0 rgba(255,183,0,0);}}
.player-card{cursor:pointer;}
.pp-back{font-family:'Share Tech Mono',monospace;font-size:.65rem;background:var(--card-bg);border:1px solid var(--border);color:var(--text);padding:.4rem .9rem;border-radius:3px;cursor:pointer;margin-bottom:1.25rem;}
.pp-back:hover{border-color:var(--tab);}
.pp-head{display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:.5rem;}
.pp-title{font-family:'Share Tech Mono',monospace;font-size:1.4rem;color:var(--text);}
.pp-byline{color:var(--dim);font-size:.8rem;margin:.3rem 0 1rem;}
.pp-cols{display:grid;grid-template-columns:384px 1fr;gap:1.5rem;align-items:start;}
@media(max-width:700px){.pp-cols{grid-template-columns:1fr;}}
.pp-shot{width:100%;max-width:384px;display:block;border:1px solid var(--border);border-radius:4px;image-rendering:pixelated;image-rendering:crisp-edges;}
.pinfo{width:100%;border-collapse:collapse;border:1px solid var(--border);border-radius:4px;overflow:hidden;font-size:.78rem;}
.pinfo td{padding:.5rem .9rem;border-top:1px solid rgba(37,37,80,.4);vertical-align:top;}
.pinfo tr:first-child td{border-top:none;}
.pinfo td:first-child{color:var(--dim);white-space:nowrap;}
.pinfo td:last-child{color:var(--text);width:100%;}
.pinfo tr.sec td{font-family:'Share Tech Mono',monospace;font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;padding:.45rem .9rem;white-space:normal;}
.pinfo tr.sec-package td{background:rgba(255,136,68,.12);color:var(--orange);}
.pinfo tr.sec-features td{background:rgba(255,183,0,.12);color:var(--amber);}
.pinfo tr.sec-player td{background:rgba(34,204,221,.12);color:var(--tab);}
.pinfo tr.sec-editor td{background:rgba(85,221,136,.12);color:var(--green);}
footer{border-top:1px solid var(--border);text-align:center;padding:1.75rem 2rem;font-family:'Share Tech Mono',monospace;font-size:.7rem;color:var(--dim);line-height:2;}
footer a{color:var(--cyan);text-decoration:none;}
footer a:hover{text-decoration:underline;}
@media print{
  .theme-toggle,.tabs-wrap,.search-bar,.rand-btn{display:none !important;}
  body{background:#fff !important;color:#000 !important;}
  .card{break-inside:avoid;border:1px solid #999 !important;background:#fff !important;}
  .mn,.bar-label{color:#000 !important;}
  .raster{display:none;}
  a{color:#000 !important;text-decoration:underline !important;}
}
</style>
</head>
<body>
<div class="raster"></div>
<button class="theme-toggle" id="theme-toggle" onclick="toggleTheme()">
  <span id="theme-icon">🌙</span><span id="theme-label">Dark</span>
</button>
<header>
  <div class="chip-label">SID CHIP · MOS 6581/8580 · LIVE FROM DEEPSID</div>
  <h1>SID <em>REFERENCE</em></h1>
  <p class="sub">Composers, players, and documentation gaps — fetched live from the DeepSID API</p>
  <div class="pills" id="pills"></div>
</header>
<div class="tabs-wrap"><div class="tabs" id="tabs"></div></div>
<div class="search-bar" id="search-bar">
  <input type="text" id="search-input" placeholder="Filter this tab…" oninput="applyFilter(this.value)">
  <select id="sort-select" onchange="applySort(this.value)" style="display:none"></select>
  <span id="search-count"></span>
  <button class="rand-btn" onclick="randomComposer()">🎲 Random composer</button>
</div>
<div class="cat-header" id="cat-header">
  <div class="cat-title" id="cat-title"></div>
  <div class="cat-desc" id="cat-desc"></div>
</div>
<div class="grid" id="grid"></div>
<footer>
  <a href="https://www.hvsc.c64.org/" target="_blank">HVSC</a> · <a href="https://deepsid.chordian.net/" target="_blank">DeepSID</a> · <a href="https://csdb.dk/" target="_blank">CSDb</a><br>
  <span id="gen-time"></span>
</footer>

<script>
/*__SID_DATA_INJECTION_POINT__*/

// Fallback if build-html.js hasn't been run yet / no data cached
window.SID_DATA = window.SID_DATA || { generatedAt: null, composers: [], players: [], gaps: [] };

// ── THEME TOGGLE ──────────────────────────────────────────────────────────
function applyTheme(theme){
  document.documentElement.setAttribute('data-theme', theme);
  document.getElementById('theme-icon').textContent = theme==='light' ? '☀️' : '🌙';
  document.getElementById('theme-label').textContent = theme==='light' ? 'Light' : 'Dark';
  try{ localStorage.setItem('sid-ref-theme', theme); }catch(e){}
}
function toggleTheme(){
  const cur = document.documentElement.getAttribute('data-theme') || 'dark';
  applyTheme(cur==='light' ? 'dark' : 'light');
}
(function initTheme(){
  let saved=null;
  try{ saved = localStorage.getItem('sid-ref-theme'); }catch(e){}
  if(!saved){
    saved = (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) ? 'light' : 'dark';
  }
  applyTheme(saved);
})();

// ── COUNTRY FLAGS (cosmetic only — falls back to a globe if unmapped) ──────
const FLAGS = {
  'Australia':'🇦🇺','Austria':'🇦🇹','Belgium':'🇧🇪','Brazil':'🇧🇷','Canada':'🇨🇦',
  'Croatia':'🇭🇷','Czech Republic':'🇨🇿','Denmark':'🇩🇰','Estonia':'🇪🇪','Finland':'🇫🇮',
  'France':'🇫🇷','Germany':'🇩🇪','Greece':'🇬🇷','Hungary':'🇭🇺','Iceland':'🇮🇸',
  'Ireland':'🇮🇪','Italy':'🇮🇹','Japan':'🇯🇵','Latvia':'🇱🇻','Lithuania':'🇱🇹',
  'Netherlands':'🇳🇱','New Zealand':'🇳🇿','Norway':'🇳🇴','Poland':'🇵🇱','Portugal':'🇵🇹',
  'Russia':'🇷🇺','Slovakia':'🇸🇰','Slovenia':'🇸🇮','Spain':'🇪🇸','Sweden':'🇸🇪',
  'Switzerland':'🇨🇭','Ukraine':'🇺🇦','United Kingdom':'🇬🇧','England':'🇬🇧',
  'United States':'🇺🇸','USA':'🇺🇸'
};
function flagFor(country){ return FLAGS[(country||'').trim()] || '🌐'; }

// Plain Number.prototype.toLocaleString() without an explicit locale
// argument uses the *visitor's own browser locale* — found while building
// the Insights tab: this dev environment defaults to en-DK, which uses
// "." as the thousands separator ("14.043"), not "," ("14,043"). That's
// backwards from what an English-language page's readers would expect,
// and it'd vary visitor to visitor on a page meant to be shared. Forcing
// 'en-US' everywhere a count is formatted keeps it consistent regardless
// of who's viewing it.
function fmtNum(n){ return n.toLocaleString('en-US'); }
function imgFallback(el, flag){
  const div = document.createElement('div');
  div.className = 'flag';
  div.textContent = flag;
  el.replaceWith(div);
}

// ── TABS ─────────────────────────────────────────────────────────────────
// `sorts` is optional — only the tabs that are genuinely long, similarly-
// shaped lists (as opposed to the bar-chart tabs, which are already sorted
// by their one meaningful dimension: magnitude) get a sort control. The
// first entry in each tab's `sorts` array is that tab's default whenever
// you switch onto it.
const TABS = [
  {id:'composers', label:'Composers',          desc:'Every composer fetched from DeepSID so far — profile bio, country, and HVSC file count.', sorts:[
    {value:'name-asc',    label:'Name (A–Z)'},
    {value:'name-desc',   label:'Name (Z–A)'},
    {value:'files-desc',  label:'Most SID files'},
    {value:'active-desc', label:'Most recently active'},
  ]},
  {id:'players',   label:'Players / Editors',  desc:'DeepSID\'s own curated players/editors database, plus every other distinct player tag actually used on a SID file that DeepSID doesn\'t have an entry for.', sorts:[
    {value:'usage-desc',    label:'Most used'},
    {value:'name-asc',      label:'Name (A–Z)'},
    {value:'year-desc',     label:'Newest first'},
    {value:'year-asc',      label:'Oldest first'},
    {value:'inferred-only', label:'Inferred only (most used first)'},
  ]},
  {id:'files',     label:'SID Files',          desc:'Every known SID file, grouped by composer. Expand a composer for a sortable grid of its files; narrow with the find box, the facet filters, or by clicking a column header.', sorts:[
    {value:'composer-asc', label:'Composer (A–Z)'},
    {value:'composer-desc',label:'Composer (Z–A)'},
    {value:'files-desc',   label:'Most files first'},
    {value:'files-asc',    label:'Fewest files first'},
  ]},
  {id:'countries', label:'Countries',          desc:'Composer count by country, derived from fetched profile data.'},
  {id:'families',  label:'Player Families',    desc:'Players/editors grouped by developer, plus known import/derivation links between tools.'},
  {id:'groups',    label:'Scene Groups',       desc:'Composers grouped by demoscene/cracking group membership, from CSDb — who made music for whom.'},
  {id:'insights',  label:'Insights',           desc:'Aggregate charts across the whole dataset — activity over time, scene roles, most prolific composers.'},
  {id:'gaps',      label:'Documentation Gaps', desc:'Sparse fields flagged by find-gaps.js — candidates for reporting upstream.', sorts:[
    {value:'type-asc',     label:'Type'},
    {value:'composer-asc', label:'Composer (A–Z)'},
  ]}
];

let currentTab = 'composers';
let currentFilter = '';
let currentSort = '';

function renderPills(){
  const d = window.SID_DATA;
  const gen = d.generatedAt ? new Date(d.generatedAt).toLocaleString() : null;
  document.getElementById('pills').innerHTML = `
    <span class="pill"><strong>${(d.composers||[]).length}</strong> composers cached</span>
    <span class="pill"><strong>${(d.players||[]).length}</strong> players/editors</span>
    <span class="pill"><strong>${(d.gaps||[]).length}</strong> known gaps</span>
    <span class="pill">Generated <strong>${gen || 'never'}</strong></span>`;
  document.getElementById('gen-time').textContent = gen
    ? `Data generated ${gen}`
    : 'No data yet — run npm run all (see README.md)';
}

function renderTabs(){
  document.getElementById('tabs').innerHTML = TABS.map(t =>
    `<button class="tab${t.id===currentTab?' on':''}" data-t="${t.id}" onclick="render('${t.id}')">${t.label}</button>`
  ).join('');
}

function emptyState(msg, cmd){
  return `<div class="empty-state">
    <p>${msg}</p>
    ${cmd ? `<p style="margin-top:.75rem"><code>${cmd}</code></p>` : ''}
  </div>`;
}

function applyFilter(v){ currentFilter = v.toLowerCase(); render(currentTab); }
function applySort(v){ currentSort = v; render(currentTab); }

function render(tab){
  const tabChanged = tab !== currentTab;
  currentTab = tab;
  renderTabs();
  // Undo whatever renderPlayerPage() hid — every normal tab render should
  // restore these regardless of how the user got here (Back button, or
  // clicking a different tab directly while a player page is open).
  document.getElementById('search-bar').style.display = '';
  document.getElementById('cat-header').style.display = '';
  const meta = TABS.find(t => t.id === tab);
  document.getElementById('cat-title').textContent = meta.label;
  document.getElementById('cat-desc').textContent = meta.desc;
  document.getElementById('search-input').placeholder = `Filter ${meta.label.toLowerCase()}…`;

  // Reset to this tab's own default sort only on an actual tab switch —
  // not on every re-render (typing in the filter box, or picking a sort
  // option, both re-render the same tab and must not stomp on the choice
  // the user just made).
  if (tabChanged) currentSort = (meta.sorts && meta.sorts[0]) ? meta.sorts[0].value : '';
  // The Files tab keeps its own facet/column-sort/expansion state (below);
  // like currentSort, it resets only on an actual switch onto the tab, never
  // on a filter keystroke or sort change that just re-renders the same tab.
  if (tabChanged && tab === 'files') {
    fileFacets.source = fileFacets.ident = fileFacets.info = fileFacets.tool = '';
    fileColSort = { col: 'title', dir: 'asc' };
    _expandedComposers.clear();
  }
  const sortSelect = document.getElementById('sort-select');
  if (meta.sorts && meta.sorts.length) {
    sortSelect.style.display = '';
    sortSelect.innerHTML = meta.sorts.map((s) => `<option value="${s.value}"${s.value === currentSort ? ' selected' : ''}>${s.label}</option>`).join('');
  } else {
    sortSelect.style.display = 'none';
    sortSelect.innerHTML = '';
  }

  const grid = document.getElementById('grid');
  if (tab === 'composers') return renderComposers(grid);
  if (tab === 'players') return renderPlayers(grid);
  if (tab === 'files') return renderFiles(grid);
  if (tab === 'countries') return renderCountries(grid);
  if (tab === 'families') return renderFamilies(grid);
  if (tab === 'groups') return renderGroups(grid);
  if (tab === 'insights') return renderInsights(grid);
  if (tab === 'gaps') return renderGaps(grid);
}

function fileList(c){
  return c.files || [];
}

function cleanNotable(s){
  return (s || '').replace(/\[#\]/g, '');
}

// ── SID FILE ↔ PLAYER LINKING ───────────────────────────────────────────
// Each SID file's `player` field is DeepSID's free-text identification of
// which player/editor routine produced it (e.g. "GoatTracker 2.62"). The
// players/editors database's `title` field is similarly free text but
// rarely matches exactly (e.g. "GoatTracker v2.x") — there's no shared ID
// between the two. Version numbers are stripped before comparing so
// "GoatTracker 2.62" and "GoatTracker v2.x" both normalize to the same
// "goattracker" and match on product name alone.
function normalizePlayerName(s){
  return (s || '')
    .toLowerCase()
    .replace(/v?\d+(\.\d+)*\.?[a-z]?/g, '')
    .replace(/[^a-z]+/g, ' ')
    .trim();
}
// Version-preserving normalizer — tried first, so "GoatTracker_V1.x" and
// "GoatTracker_V2.x" resolve to their own distinct player entries instead
// of both collapsing onto whichever "goattracker"-rooted entry the
// version-stripped normalizer happens to hit first (a real bug found while
// building a usage-count feature: it was silently attributing every
// GoatTracker v1.x file to the v2.x card, and same for DMC's 3 versions).
function normalizePlayerNameStrict(s){
  return (s || '').toLowerCase().replace(/[^a-z0-9]+/g, '');
}
function matchPlayer(filePlayer, players){
  const strict = normalizePlayerNameStrict(filePlayer);
  if (strict.length >= 3) {
    const strictMatches = players.filter(p => {
      const ps = normalizePlayerNameStrict(p.title);
      return ps && ps.length >= 3 && (ps === strict || strict.includes(ps) || ps.includes(strict));
    });
    if (strictMatches.length === 1) return strictMatches[0];
    if (strictMatches.length > 1) {
      const exact = strictMatches.find((p) => normalizePlayerNameStrict(p.title) === strict);
      if (exact) return exact; // true equality beats a substring guess between multiple candidates
      // Prefer the most specific (longest normalized) candidate, but only
      // when it clearly beats the runner-up — e.g. "SidFactory_II/Laxity"
      // matches both "SID Factory" and "SID Factory II" as substrings, and
      // the longer one is obviously the real, more specific match. When two
      // candidates are equally specific (e.g. a bare "DMC" matching v4/v5/v6
      // with nothing to prefer between them), that's genuine ambiguity —
      // don't guess.
      const byLength = [...strictMatches].sort((a, b) => normalizePlayerNameStrict(b.title).length - normalizePlayerNameStrict(a.title).length);
      if (normalizePlayerNameStrict(byLength[0].title).length > normalizePlayerNameStrict(byLength[1].title).length) return byLength[0];
      return null; // genuinely ambiguous even at the strict level — don't guess
    }
  }
  // No version-intact match at all (e.g. a bare "DMC" with no version, or
  // "GoatTracker instruments" naming no version) — fall back to the
  // version-stripped match, but only when it's unambiguous. Returning the
  // "first found" among several same-family candidates would misattribute
  // a file to a specific version it can't actually be confirmed to be.
  const norm = normalizePlayerName(filePlayer);
  if (norm.length < 3) return null;
  const looseMatches = players.filter((p) => {
    const pn = normalizePlayerName(p.title);
    return pn && pn.length >= 3 && (pn.includes(norm) || norm.includes(pn));
  });
  return looseMatches.length === 1 ? looseMatches[0] : null;
}

// ── SIDId ENRICHMENT ─────────────────────────────────────────────────────
// window.SID_DATA.sidid maps raw player tags → {name,author,released,
// reference,comment} from the SIDId database (scripts/import-sidid.js).
// This is the only spec source for the inferred players — DeepSID's own
// curated database has nothing for them. Tag matching mirrors matchPlayer()
// exactly: exact tag first, then a version-intact strict norm, then the
// version-stripped loose norm — and the two normalized tiers resolve only
// when unambiguous (a collision nulls the key), never guessing an identity
// from an ambiguous partial. Covers ~83% of all files' tags in practice.
let _sididIndex = null;
function buildSididIndex(){
  const byTag = window.SID_DATA.sidid || {};
  const strict = new Map();
  const loose = new Map();
  const add = (map, key, entry) => {
    if (!key || key.length < 3) return;
    if (map.has(key) && map.get(key) !== entry) map.set(key, null); // collision → ambiguous
    else if (!map.has(key)) map.set(key, entry);
  };
  Object.keys(byTag).forEach((tag) => {
    const entry = byTag[tag];
    add(strict, normalizePlayerNameStrict(tag), entry);
    add(loose, normalizePlayerName(tag), entry);
  });
  _sididIndex = { byTag, strict, loose };
}
function lookupSidid(rawTag){
  if (!rawTag) return null;
  if (!_sididIndex) buildSididIndex();
  const { byTag, strict, loose } = _sididIndex;
  if (byTag[rawTag]) return byTag[rawTag];                    // exact tag
  const s = strict.get(normalizePlayerNameStrict(rawTag));    // version-intact
  if (s) return s;
  return loose.get(normalizePlayerName(rawTag)) || null;      // version-stripped, unambiguous only
}
// Same resolution, but keyed off a curated player's free-text title (which
// carries a version suffix DeepSID's tags don't, e.g. "GoatTracker v2.x")
// rather than a raw file tag. Used only to graft SIDId's additive bits (the
// playback-technique comment, an extra reference) onto curated players —
// never to override their authoritative DeepSID specs.
function lookupSididByTitle(title){
  if (!title) return null;
  if (!_sididIndex) buildSididIndex();
  const { byTag, strict, loose } = _sididIndex;
  if (byTag[title]) return byTag[title];
  const s = strict.get(normalizePlayerNameStrict(title));
  if (s) return s;
  return loose.get(normalizePlayerName(title)) || null;
}
// Pull the leading 4-digit year out of a SIDId "RELEASED" line (e.g.
// "1989 Hitech Studio Designs" → "1989") for the player's start_year.
function sididYear(released){
  const m = /\b(19|20)\d{2}\b/.exec(released || '');
  return m ? m[0] : null;
}

// DeepSID's own `?players` database (129 entries) is curated — real specs,
// developer credit, platform. But individual SID files' free-text `player`
// field names 605 distinct raw strings, and 496 of those never made it into
// the curated 129 at all (17,538 files, ~32% of the whole collection) — a
// bare "DMC" (2,878 files, DeepSID's curated list only has versioned DMC
// v4/v5/v6.x), "JCH_NewPlayer_V9" through "V20" as individual entries, or a
// composer's own hand-coded in-game routine (e.g. "Rob_Hubbard",
// "David_Whittaker" — a real, distinguishable player routine, just never
// written up as a product with a spec sheet). These get synthesized into
// player-shaped objects (`inferred: true`, no spec data — there isn't any
// to show) and merged into the same players array everything else already
// reads, so the Files tab's "no match found" tags, the Players tab, and
// usage counts all pick them up for free instead of needing separate
// wiring. Deliberately not filtered by a minimum file count — even a
// single-file tag is still real data DeepSID's own curated list is
// missing, and the Players tab's own sort/filter already surfaces the
// common ones first.
function cleanRawPlayerTag(tag){
  return tag.replace(/_/g, ' ').trim();
}
function deriveSyntheticPlayers(files, knownPlayers){
  const rawCounts = new Map();
  files.forEach((f) => {
    if (!f.player) return;
    rawCounts.set(f.player, (rawCounts.get(f.player) || 0) + 1);
  });
  const synthetic = [];
  rawCounts.forEach((count, tag) => {
    if (matchPlayer(tag, knownPlayers)) return; // already covered by a real, curated entry
    // SIDId often has the author/name/year DeepSID's curated DB never wrote
    // up for this tag — surface it as the inferred player's developer/year
    // (so it shows on the card and sorts by year) and keep the full record
    // (incl. the technique comment) under `sidid` for the detail page.
    const sid = lookupSidid(tag);
    synthetic.push({
      title: cleanRawPlayerTag(tag),
      developer: (sid && sid.author) || null,
      platform: null,
      start_year: (sid && sididYear(sid.released)) || null,
      end_year: null,
      description: null, screenshot: null, csdb_id: null,
      inferred: true, rawTag: tag,
      sidid: sid || null,
    });
  });
  return synthetic;
}

// How many files across the whole collection were actually made with each
// player/editor — real usage, not just "this tool exists in the database".
// Cached at module level (same pattern as allFiles()) since it's an O(files
// x players) scan and the Players tab re-renders on every search keystroke.
let _playerUsageCache = null;
function computePlayerUsageCounts(players, files){
  if (_playerUsageCache) return _playerUsageCache;
  const counts = new Map();
  files.forEach(f => {
    if (!f.player) return;
    const match = matchPlayer(f.player, players);
    if (match) counts.set(match.title, (counts.get(match.title) || 0) + 1);
  });
  _playerUsageCache = counts;
  return counts;
}

const FILE_LIST_CAP = 50;

function buildFileRow(f, players, composerPath){
  const url = (composerPath && f.file) ? `https://deepsid.chordian.net/?file=${composerPath.replace(/^\//,'')}${f.file}` : null;
  const label = f.title || f.file || '(untitled)';
  const nameEl = url
    ? `<a class="file-name" href="${url}" target="_blank">${label}</a>`
    : `<span class="file-name">${label}</span>`;
  const commentEl = f.comment ? `<div><button class="cnote-btn" onclick="toggleFiles(this)">▸ song info</button><div class="mp-desc" style="display:none;max-width:420px">${f.comment}</div></div>` : '';
  const playerText = (f.player || '').trim();
  if (!playerText) return `<div class="file-row">${nameEl}<span class="tag">unidentified player</span></div>${commentEl}`;
  const match = matchPlayer(playerText, players);
  const playerEl = match
    ? `<span class="tag" title="Linked to players/editors: ${match.title}">${playerText}</span>`
    : `<span class="tag" title="No match found in players/editors database">${playerText}</span>`;
  return `<div class="file-row">${nameEl}${playerEl}</div>${commentEl}`;
}

function toggleFiles(btn){
  const wrap = btn.nextElementSibling;
  const open = wrap.style.display !== 'none';
  wrap.style.display = open ? 'none' : 'block';
  btn.textContent = btn.textContent.replace(open ? '▾' : '▸', open ? '▸' : '▾');
}

// DeepSID's date fields use "0000-00-00" for "unknown", not a blank
// string, and a death date can be year-only-known ("2018-00-00") — this
// treats any leading "0000" as absent and otherwise just takes the year.
function deathYear(dateStr){
  if (!dateStr || dateStr.startsWith('0000')) return null;
  const year = dateStr.slice(0, 4);
  return /^\d{4}$/.test(year) ? year : null;
}

function buildComposerCard(c){
  const p = c.profile || {};
  const files = fileList(c);
  const players = window.SID_DATA.players || [];
  const badge = p.thumbnail
    ? `<img class="thumb" src="${p.thumbnail}" alt="${c.name}" loading="lazy" onerror="imgFallback(this,'${flagFor(p.country)}')">`
    : `<div class="flag">${flagFor(p.country)}</div>`;
  const fullName = p.full_name && p.full_name !== c.name ? `<div class="mh">${p.full_name}</div>` : '';
  const csdbGroups = (c.csdb && c.csdb.groups || []).map(g => `<span class="tag">${g.name}</span>`).join('');
  const tags = [p.focus2, p.affiliation]
    .filter(t => t && t !== 'NONE')
    .map(t => `<span class="tag">${t}</span>`).join('') + csdbGroups;
  // "Musician" is filtered out — every card here is a SID composer by
  // definition, so it's not informative. What is informative: CSDb credits
  // most of them for other scene roles too (57% of enriched composers),
  // so this is usually the tag row that shows "not just a musician".
  const otherRoles = ((c.csdb && c.csdb.roles) || []).filter((r) => r !== 'Musician');
  const roleTags = otherRoles.length
    ? `<div class="tags" title="Other scene roles credited on CSDb, besides music" style="margin-top:.3rem">${otherRoles.map((r) => `<span class="tag">${r}</span>`).join('')}</div>`
    : '';
  const bio = cleanNotable(p.notable);
  const died = deathYear(p.date_death);
  const memoriam = died
    ? `<div class="meta" style="margin-top:.3rem" title="${p.death_cause ? `Cause: ${p.death_cause}` : 'No further detail recorded'}">🕯 In memoriam, ${died}</div>`
    : '';
  const dsUrl = `https://deepsid.chordian.net/?file=${c.path}`;
  const csdbUrl = p.csdb_id ? `https://csdb.dk/scener/?id=${p.csdb_id}` : null;

  let verifyBadge = '';
  if (c.hvsc && c.hvsc.countryMismatch) {
    verifyBadge = `<span class="tag warn" title="DeepSID: ${p.country || '?'} · HVSC Musicians.txt: ${c.hvsc.country}">⚠ country mismatch</span>`;
  } else if (c.hvsc) {
    verifyBadge = `<span class="tag ok" title="Matches HVSC Musicians.txt: ${c.hvsc.country || 'no country listed'}">✓ HVSC verified</span>`;
  }

  const fileRows = files.slice(0, FILE_LIST_CAP).map(f => buildFileRow(f, players, c.path)).join('');
  const fileMore = files.length > FILE_LIST_CAP
    ? `<div class="file-row"><span class="file-name" style="color:var(--dim)">+${files.length - FILE_LIST_CAP} more — see DeepSID</span></div>`
    : '';
  const filesSection = files.length
    ? `<button class="cnote-btn" onclick="toggleFiles(this)">▸ ${files.length} SID${files.length===1?'':'s'}</button>
       <div class="file-list" style="display:none">${fileRows}${fileMore}</div>`
    : `<span class="cnote">0 SIDs</span>`;

  return `<div class="card" data-name="${c.name.toLowerCase()}">
    <div class="card-top">
      ${badge}
      <div class="nb"><div class="mn">${c.name}</div>${fullName}</div>
    </div>
    <div class="meta"><span>${flagFor(p.country)} ${p.country || 'Unknown'}</span><span class="dot">·</span><span>${p.active || '—'}</span></div>
    ${verifyBadge ? `<div class="tags">${verifyBadge}</div>` : ''}
    ${tags ? `<div class="tags">${tags}</div>` : ''}
    ${roleTags}
    ${memoriam}
    ${bio ? `<div class="bio">${bio}</div>` : ''}
    <div class="cfoot">
      <a class="dslink" href="${dsUrl}" target="_blank">▶ DeepSID</a>
      ${csdbUrl ? `<a class="dslink" href="${csdbUrl}" target="_blank">CSDb${c.csdb ? ` (${c.csdb.creditCount})` : ''}</a>` : ''}
      ${filesSection}
    </div>
  </div>`;
}

// DeepSID's date/year fields use "0000..." for "unknown" — same convention
// deathYear() already handles for date_death, reused here for active year.
function activeYear(active){
  if (!active || active.startsWith('0000')) return null;
  const year = parseInt(active.slice(0, 4), 10);
  return year || null;
}

function sortComposers(list, sort){
  const sorted = [...list];
  if (sort === 'name-desc') sorted.sort((a, b) => b.name.localeCompare(a.name));
  else if (sort === 'files-desc') sorted.sort((a, b) => (b.files || []).length - (a.files || []).length);
  else if (sort === 'active-desc') sorted.sort((a, b) => (activeYear(b.profile && b.profile.active) || 0) - (activeYear(a.profile && a.profile.active) || 0));
  else sorted.sort((a, b) => a.name.localeCompare(b.name)); // name-asc, and the default
  return sorted;
}

function renderComposers(grid){
  grid.style.gridTemplateColumns = '';
  let list = window.SID_DATA.composers || [];
  if (currentFilter) list = list.filter(c => c.name.toLowerCase().includes(currentFilter));
  list = sortComposers(list, currentSort);
  document.getElementById('search-count').textContent = `${list.length} shown`;
  if (list.length === 0) {
    grid.innerHTML = emptyState('No composer data cached yet.', 'node scripts/fetch-composers.js');
    return;
  }
  grid.innerHTML = list.map(buildComposerCard).join('');
}

function renderPlayers(grid){
  grid.style.gridTemplateColumns = '';
  let list = window.SID_DATA.players || [];
  if (currentFilter) list = list.filter(p => (p.title||'').toLowerCase().includes(currentFilter));
  // "Inferred only" doubles as a filter, not just a sort — isolates the
  // 496 tags DeepSID's own database doesn't have an entry for, so you can
  // work through them one at a time (most-used first, since those are the
  // ones most worth tracking down) instead of hunting for them mixed in
  // among the 129 real, already-documented ones.
  if (currentSort === 'inferred-only') list = list.filter((p) => p.inferred);
  if (list.length === 0) {
    document.getElementById('search-count').textContent = '0 shown';
    grid.innerHTML = emptyState('No player/editor data cached yet.', 'node scripts/fetch-players.js');
    return;
  }
  const allPlayers = window.SID_DATA.players || [];
  const families = computePlayerFamilies(allPlayers);
  const usageCounts = computePlayerUsageCounts(allPlayers, allFiles());

  // Default sorts by real usage (files actually made with each tool), not
  // insertion order — puts the tools that mattered most to the scene
  // first, e.g. GoatTracker's ~8,400 files across its two major versions.
  // Other sort options (name, start year) are user-selectable via the
  // sort dropdown, same currentSort mechanism as the Composers tab.
  // "Inferred only" also sorts by usage — same ordering rationale.
  list = [...list].sort((a, b) => {
    if (currentSort === 'name-asc') return (a.title || '').localeCompare(b.title || '');
    if (currentSort === 'year-desc') return (parseInt(b.start_year, 10) || 0) - (parseInt(a.start_year, 10) || 0);
    if (currentSort === 'year-asc') return (parseInt(a.start_year, 10) || 9999) - (parseInt(b.start_year, 10) || 9999);
    return (usageCounts.get(b.title) || 0) - (usageCounts.get(a.title) || 0); // usage-desc / inferred-only, and the default
  });
  const knownCount = list.filter((p) => !p.inferred).length;
  const inferredCount = list.length - knownCount;
  document.getElementById('search-count').textContent = currentSort === 'inferred-only'
    ? `${fmtNum(inferredCount)} inferred players shown, most-used first — click one to see which composers/files used it`
    : inferredCount
      ? `${list.length} shown (${fmtNum(knownCount)} in DeepSID's own database, ${fmtNum(inferredCount)} inferred from file data) — click one for full specs`
      : `${list.length} shown — click one for full specs`;

  grid.innerHTML = list.map((p) => {
    const years = `${p.start_year || '?'}–${p.end_year || 'present'}`;
    const devKey = stripTags(p.developer) || '(unknown developer)';
    const sibCount = ((families[devKey] && families[devKey].titles.length) || 1) - 1;
    const usage = usageCounts.get(p.title) || 0;
    const idx = allPlayers.indexOf(p);
    const tags = [
      usage ? `<span class="tag ok">${fmtNum(usage)} file${usage === 1 ? '' : 's'}</span>` : '',
      sibCount > 0 ? `<span class="tag">+${sibCount} sibling tool${sibCount === 1 ? '' : 's'}</span>` : '',
      p.inferred ? `<span class="tag" title="Not in DeepSID's own players database — this entry is derived from the raw player field on SID files that used it">inferred</span>` : '',
    ].filter(Boolean).join('');
    return `<div class="card player-card" onclick="renderPlayerPage(${idx})">
      <div class="card-top">
        <div class="flag">🎚</div>
        <div class="nb"><div class="mn">${p.title || '(untitled)'}</div><div class="mh">${p.inferred ? (p.developer ? `${p.developer} · inferred` : 'Inferred from file data') : (p.developer || 'Unknown developer')}</div></div>
      </div>
      <div class="meta"><span>${p.platform || 'Unknown platform'}</span><span class="dot">·</span><span>${years}</span></div>
      ${tags ? `<div class="tags">${tags}</div>` : ''}
    </div>`;
  }).join('');
}

/**
 * A dedicated full "page" view (not an inline expand) — mirrors the
 * layout of DeepSID's own player detail page (title, byline, download
 * link, then Package/Features/Player/Editor spec sections) using this
 * project's own visual theme, populated entirely from the already-cached
 * players.json — no scraping involved (every field on DeepSID's actual
 * page already exists in that JSON; verified field-by-field before
 * building this). Screenshot images from that page aren't reproduced
 * here — no reliable source for them (DeepSID's players page is a
 * JS-rendered SPA with no predictable image URL) and they're screenshots
 * of the editors' own UI, not something to embed without a real source.
 */
// Field → label → section mapping, matching DeepSID's own grouping
// (checked its player.php on GitHub, per the user's pointer) — a real
// <table> instead of the earlier flex-based rows, since that's what
// actually fixes uneven-width label/value wrapping: table columns
// auto-size to content instead of needing a guessed fixed pixel width.
// `file_format` (DeepSID's "Proprietary file format" row) is skipped —
// it's in their DB but not in the public ?players API response this
// project reads (0 of 129 cached players have it), so there's no data
// to show honestly.
const PLAYER_INFO_SECTIONS = [
  ['package', '📦 Package', [
    ['Platform', 'platform'], ['Distribution', 'distribution'], ['PAL / NTSC', 'encoding'],
    ['Source code', 'source_code'], ['Documentation', 'docs'], ['Example tunes', 'example_tunes'],
  ]],
  ['features', '✓ Features', [
    ['Number of SID chips', 'sid_chip_count'], ['Channels visible', 'channels_visible'],
    ['Speeds', 'speeds'], ['Digi / Samples', 'digi'], ['Auxiliary support', 'aux_support'],
    ['Import from', 'import_from'], ['Save/Export to', 'save_to'], ['Packer', 'packer'],
    ['Relocator', 'relocator'], ['Load/Save sounds', 'load_save_snd'],
    ['Instruments / Sounds', 'instruments'], ['Sub tunes', 'subtunes'],
  ]],
  ['player', '🎚 Player', [
    ['Noteworthy', 'noteworthy'], ['Size of player', 'player_size'], ['Zero page usage', 'zero_pages'],
    ['CPU time (1x)', 'cpu_time'], ['Arpeggio', 'arpeggio'], ['Pulsating', 'pulsating'],
    ['Filtering', 'filtering'], ['Vibrato', 'vibrato'], ['Hard restart', 'hard_restart'],
  ]],
  ['editor', '🗂 Editor', [
    ['Track system', 'track_system'], ['Patterns / Sequences', 'patterns'], ['Follow-play', 'follow_play'],
    ['Copy and Paste', 'copy_paste'], ['Undo', 'undoing'], ['Track commands', 'track_cmds'],
    ['Note input layout', 'note_input'],
  ]],
];

function buildPlayerInfoTable(p){
  const rows = PLAYER_INFO_SECTIONS.map(([key, label, fields]) => {
    const filled = fields.filter(([,f]) => p[f] && String(p[f]).trim());
    if (!filled.length) return '';
    const header = `<tr class="sec sec-${key}"><td colspan="2">${label}</td></tr>`;
    const body = filled.map(([k,f]) => `<tr><td>${k}</td><td>${p[f]}</td></tr>`).join('');
    return header + body;
  }).join('');
  return `<table class="pinfo">${rows}</table>`;
}

function renderPlayerPage(index){
  const players = window.SID_DATA.players || [];
  const p = players[index];
  if (!p) return;
  const families = computePlayerFamilies(players);
  const files = allFiles();

  const years = `${p.start_year || '?'}–${p.end_year || 'present'}`;
  const csdbUrl = p.csdb_id ? `https://csdb.dk/release/?id=${p.csdb_id}` : null;
  const infoBox = buildPlayerInfoTable(p);

  const devKey = stripTags(p.developer) || '(unknown developer)';
  const siblings = ((families[devKey] && families[devKey].titles) || []).filter(t => t !== p.title);
  const used = filesForPlayer(p, files, players);
  const usedRows = used.slice(0, 40).map(f =>
    `<div class="file-row"><a class="file-name" href="${deepsidFileUrl(f) || '#'}" target="_blank">${f.composer} — ${f.title || f.file}</a></div>`
  ).join('');
  const usedMore = used.length > 40 ? `<div class="file-row"><span class="file-name" style="color:var(--dim)">+${used.length-40} more</span></div>` : '';

  // Research aid for inferred players (there's no spec data to show, so
  // this is the next best thing): how concentrated is usage among
  // composers? A player used almost exclusively by one or two composers
  // is very likely their own personal/hand-coded routine rather than a
  // shared tool worth writing up separately — worth knowing before
  // spending time trying to identify it as a "real" product.
  let composerHint = '';
  if (p.inferred && used.length) {
    const byComposer = new Map();
    used.forEach((f) => byComposer.set(f.composer, (byComposer.get(f.composer) || 0) + 1));
    const ranked = [...byComposer.entries()].sort((a, b) => b[1] - a[1]);
    const topShare = Math.round((100 * ranked[0][1]) / used.length);
    if (ranked.length <= 3) {
      composerHint = `Used by just ${ranked.length} composer${ranked.length === 1 ? '' : 's'}: ${ranked.map(([n, c]) => `${n} (${c})`).join(', ')} —
        likely a personal/hand-coded routine, not a shared tool.`;
    } else if (topShare >= 60) {
      composerHint = `${topShare}% of files (${ranked[0][1]} of ${used.length}) are by <a href="#" onclick="jumpToComposer('${ranked[0][0].replace(/'/g, "\\'")}');return false;" style="color:inherit">${ranked[0][0]}</a> alone —
        likely mostly their own routine, even though ${ranked.length} composers in total used it.`;
    } else {
      composerHint = `Spread across ${ranked.length} different composers (top: ${ranked[0][0]} with ${ranked[0][1]}) — more likely a real,
        shared tool that just never got written up in DeepSID's own database.`;
    }
  }

  // SIDId (sidid.nfo) is the one spec source for inferred players — render
  // whatever of full-name/author/year/reference/technique it carries, in the
  // same table style as a curated player's spec box.
  const sid = p.inferred ? p.sidid : null;
  const sididRows = sid ? [
    ['Full name', sid.name],
    ['Author', sid.author],
    ['Released', sid.released],
    ['Reference', sid.reference ? `<a class="dslink" href="${sid.reference}" target="_blank">${sid.reference.replace(/^https?:\/\//, '')}</a>` : ''],
    ['Technique', sid.comment],
  ].filter(([, v]) => v && String(v).trim()).map(([k, v]) => `<tr><td>${k}</td><td>${v}</td></tr>`).join('') : '';
  const sididBox = sididRows
    ? `<table class="pinfo" style="margin-bottom:1.25rem"><tr class="sec sec-package"><td colspan="2">🔎 SIDId database (sidid.nfo)</td></tr>${sididRows}</table>`
    : '';

  // Curated players keep their authoritative DeepSID specs — SIDId only
  // grafts on its playback-technique note (and a reference, when it's a
  // different link than the download shown above) where it has one. Never
  // overrides the curated developer/name/specs. ~11 of the 129 curated
  // players gain a technique note this way (e.g. "based on the Music
  // Assembler player", a type-in-listing origin).
  // Gated on an actual technique comment — a bare SIDId reference would just
  // duplicate the CSDb download link already in the header, so those don't
  // earn a box; the reference rides along as a supporting row when a comment
  // is present.
  const curSid = p.inferred ? null : lookupSididByTitle(p.title);
  const curatedTechBox = (curSid && curSid.comment)
    ? `<table class="pinfo" style="margin-top:1.25rem"><tr class="sec sec-player"><td colspan="2">🔎 SIDId note</td></tr>` +
      `<tr><td>Technique</td><td>${curSid.comment}</td></tr>` +
      (curSid.reference && curSid.reference !== csdbUrl ? `<tr><td>Reference</td><td><a class="dslink" href="${curSid.reference}" target="_blank">${curSid.reference.replace(/^https?:\/\//, '')}</a></td></tr>` : '') +
      `</table>`
    : '';

  document.getElementById('search-bar').style.display = 'none';
  document.getElementById('cat-header').style.display = 'none';
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('on'));

  const gridEl = document.getElementById('grid');
  gridEl.style.gridTemplateColumns = '';
  gridEl.innerHTML = `<div class="fw" style="padding-top:1.5rem">
    <button class="pp-back" onclick="closePlayerPage()">← Back</button>
    <div class="pp-head">
      <div class="pp-title">${p.title || '(untitled)'}</div>
      ${csdbUrl ? `<div>Download: <a class="dslink" href="${csdbUrl}" target="_blank">CSDb</a></div>` : ''}
    </div>
    <div class="pp-byline">${p.inferred
      ? (sid && sid.author ? `${p.start_year ? p.start_year + ' · ' : ''}${sid.author} · inferred` : 'Inferred from file data — not in DeepSID\'s own players database')
      : `${years} by ${p.developer || 'unknown'}`}</div>
    ${p.description ? `<div class="bio" style="margin-bottom:1.25rem">${p.description}</div>` : ''}
    ${p.inferred ? `${sididBox}<div class="sn" style="margin-bottom:1.25rem">This player was seen on ${used.length} SID file${used.length === 1 ? '' : 's'} (raw tag:
      <code>${p.rawTag}</code>). ${sid
        ? 'The spec box above is from the SIDId database — DeepSID\'s own curated players/editors database has no entry for this tag.'
        : 'DeepSID\'s own curated players/editors database has no entry for it, and SIDId doesn\'t either, so there\'s no developer, platform, or spec info to show — just the files that used it, below.'} ${composerHint}</div>` : `
    <div class="pp-cols">
      <div>${p.screenshot ? `<img class="pp-shot" src="${p.screenshot}" alt="${p.title} screenshot" loading="lazy" onerror="this.remove()">` : ''}</div>
      <div>${infoBox}</div>
    </div>`}
    ${curatedTechBox}
    <div style="margin-top:1.5rem">
      ${siblings.length ? `<div class="sl">Same developer (${siblings.length})</div><div class="tags" style="margin-bottom:1.25rem">${siblings.map(t=>`<span class="tag">${t}</span>`).join('')}</div>` : ''}
      <div class="sl">Composers/files using this player (${used.length})</div>
      ${usedRows || '<p style="color:var(--dim);font-size:.75rem">No files currently link to this player by name — check the Files tab for unmatched entries.</p>'}
      ${usedMore}
    </div>
  </div>`;
}

function closePlayerPage(){
  render('players');
}

// ── SID FILES TAB (grouped grid) ─────────────────────────────────────────
// Every SID file, grouped under its composer, each group a sortable columnar
// grid. Three independent controls narrow the ~55,000 files: the shared
// search box ("find", across composer/title/artist/player/filename), a row
// of faceted filters (source, player-identification state, has-song-info, a
// specific tool), and per-column sort (click a column header). The shared
// sort dropdown orders the composer groups themselves. Files render lazily —
// only expanded composers build their table — so a whole-collection render
// stays cheap even at ~1,895 groups.
const FILES_PER_GROUP_CAP = 400;   // rows built per expanded composer
const AUTO_EXPAND_GROUPS = 25;     // a filter that narrows to <= this many
                                   // composers auto-expands all of them

// State specific to this tab (reset on tab switch in render(), not carried
// between visits) — the counterpart to the shared currentFilter/currentSort.
const fileFacets = { source: '', ident: '', info: '', tool: '' };
let fileColSort = { col: 'title', dir: 'asc' };
const _expandedComposers = new Set();

// matchPlayer() is O(players); memoize per distinct raw tag (~605 of them)
// so filtering/sorting 55,000 files never re-resolves the same tag twice.
// Built lazily, so it runs after synthetic players are merged (see bottom).
let _tagMatchCache = null;
function resolveTag(tag){
  if (!tag) return null;
  if (!_tagMatchCache) _tagMatchCache = new Map();
  if (_tagMatchCache.has(tag)) return _tagMatchCache.get(tag);
  const m = matchPlayer(tag, window.SID_DATA.players || []);
  _tagMatchCache.set(tag, m);
  return m;
}

// allFiles() re-flattened into per-composer groups (files stay contiguous
// in the order allFiles() yields them). Cached like allFiles() itself.
let _fileGroupsCache = null;
function fileGroups(){
  if (_fileGroupsCache) return _fileGroupsCache;
  const map = new Map();
  allFiles().forEach((f) => {
    let g = map.get(f.composer);
    if (!g) { g = { composer: f.composer, composerPath: f.composerPath, files: [] }; map.set(f.composer, g); }
    g.files.push(f);
  });
  _fileGroupsCache = [...map.values()];
  return _fileGroupsCache;
}

// Distinct resolved tools actually present on files, for the "by tool"
// facet select — sorted A–Z (case-insensitive) so a specific tool is easy
// to find in the dropdown (the file count still rides along in the label).
let _toolListCache = null;
function toolList(){
  if (_toolListCache) return _toolListCache;
  const counts = new Map();
  allFiles().forEach((f) => {
    if (!f.player) return;
    const m = resolveTag(f.player);
    const title = m ? m.title : f.player;
    counts.set(title, (counts.get(title) || 0) + 1);
  });
  _toolListCache = [...counts.entries()].sort((a, b) => a[0].localeCompare(b[0], undefined, { sensitivity: 'base' }));
  return _toolListCache;
}

function fileMatchesFilters(f){
  if (currentFilter) {
    const hay = (f.composer + ' ' + (f.title || '') + ' ' + (f.artist || '') + ' ' + (f.player || '') + ' ' + (f.file || '')).toLowerCase();
    if (!hay.includes(currentFilter)) return false;
  }
  if (fileFacets.source && f.source !== fileFacets.source) return false;
  if (fileFacets.info === 'yes' && !f.comment) return false;
  if (fileFacets.ident || fileFacets.tool) {
    const m = f.player ? resolveTag(f.player) : null;
    if (fileFacets.ident === 'has' && !f.player) return false;
    if (fileFacets.ident === 'none' && f.player) return false;
    if (fileFacets.ident === 'curated' && !(m && !m.inferred)) return false;
    if (fileFacets.ident === 'inferred' && !(m && m.inferred)) return false;
    if (fileFacets.tool) {
      const title = m ? m.title : (f.player || null);
      if (title !== fileFacets.tool) return false;
    }
  }
  return true;
}

function sortFilesInGroup(files){
  const { col, dir } = fileColSort;
  const mul = dir === 'desc' ? -1 : 1;
  const keyOf = (f) => {
    if (col === 'file') return (f.file || '').toLowerCase();
    if (col === 'player') return (f.player || '￿').toLowerCase();
    if (col === 'subtunes') return f.subtunes || 1;
    if (col === 'source') return f.source || '';
    return (f.title || f.file || '').toLowerCase(); // title (default)
  };
  return [...files].sort((a, b) => {
    const ka = keyOf(a), kb = keyOf(b);
    if (ka < kb) return -1 * mul;
    if (ka > kb) return 1 * mul;
    return (a.title || a.file || '').localeCompare(b.title || b.file || ''); // stable tiebreak
  });
}

function facetSelect(key, label, options){
  const opts = options.map(([v, l]) => `<option value="${v.replace(/"/g, '&quot;')}"${fileFacets[key] === v ? ' selected' : ''}>${l}</option>`).join('');
  return `<label class="ffilter">${label}<select onchange="setFileFacet('${key}',this.value)">${opts}</select></label>`;
}

function filesToolbar(shownFiles, groupCount){
  const tools = toolList();
  const toolOpts = [['', `Any tool (${fmtNum(tools.length)})`]].concat(tools.map(([title, n]) => [title, `${title} (${fmtNum(n)})`]));
  return `<div class="ftools">
    ${facetSelect('source', 'Source', [['', 'All'], ['deepsid', 'DeepSID'], ['stil', 'HVSC STIL']])}
    ${facetSelect('ident', 'Player', [['', 'All'], ['curated', 'Curated only'], ['has', 'Has a player'], ['inferred', 'Inferred only'], ['none', 'No player']])}
    ${facetSelect('info', 'Song info', [['', 'All'], ['yes', 'Has song info']])}
    ${facetSelect('tool', 'Tool', toolOpts)}
    <span class="ftools-count">${fmtNum(shownFiles)} files · ${fmtNum(groupCount)} composers</span>
  </div>`;
}

function colHeader(col, label){
  const active = fileColSort.col === col;
  const caret = active ? (fileColSort.dir === 'asc' ? ' ▲' : ' ▼') : '';
  return `<th class="sortable${active ? ' on' : ''}" onclick="setFileColSort('${col}')">${label}${caret}</th>`;
}

function buildFilesTable(g){
  const players = window.SID_DATA.players || [];
  const files = sortFilesInGroup(g._filtered);
  const rows = files.slice(0, FILES_PER_GROUP_CAP).map((f) => {
    const match = f.player ? resolveTag(f.player) : null;
    const matchIdx = match ? players.indexOf(match) : -1;
    const playerCell = f.player
      ? (match
          ? `<span class="tag ok" style="cursor:pointer" title="${match.inferred ? 'Inferred' : 'Curated'}: ${match.title} — click for details" onclick="renderPlayerPage(${matchIdx})">${f.player}</span>`
          : `<span class="tag" title="No match in players/editors database">${f.player}</span>`)
      : `<span class="cnote">${f.source === 'stil' ? 'unknown (STIL)' : 'not identified'}</span>`;
    const ds = deepsidFileUrl(f);
    const csdb = f.csdbId ? `https://csdb.dk/release/?id=${f.csdbId}` : null;
    const links = `${ds ? `<a class="dslink" href="${ds}" target="_blank" title="Play on DeepSID">▶</a>` : ''}${csdb ? ` <a class="dslink" href="${csdb}" target="_blank" title="CSDb release">CSDb</a>` : ''}`;
    const info = f.comment ? `<div><button class="cnote-btn" onclick="toggleFiles(this)">▸ song info</button><div class="mp-desc" style="display:none;max-width:520px">${f.comment}</div></div>` : '';
    return `<tr>
      <td style="font-family:'Share Tech Mono',monospace;font-size:.72rem;white-space:nowrap">${f.file || ''}</td>
      <td style="font-size:.75rem">${f.title || f.file || ''}${f.artist ? `<div class="mp-desc">by ${f.artist}</div>` : ''}${info}</td>
      <td>${playerCell}</td>
      <td style="text-align:center;font-size:.72rem">${f.subtunes || ''}</td>
      <td><span class="tag">${f.source}</span></td>
      <td style="white-space:nowrap">${links}</td>
    </tr>`;
  }).join('');
  const more = files.length > FILES_PER_GROUP_CAP
    ? `<tr><td colspan="6" style="color:var(--dim);font-size:.72rem">+${fmtNum(files.length - FILES_PER_GROUP_CAP)} more in this composer — narrow with find/filters</td></tr>`
    : '';
  return `<table class="mp-tbl ftbl"><thead><tr>
    ${colHeader('file', 'File')}${colHeader('title', 'Title')}${colHeader('player', 'Player')}${colHeader('subtunes', 'Sub')}${colHeader('source', 'Source')}<th>Links</th>
  </tr></thead><tbody>${rows}${more}</tbody></table>`;
}

function setFileFacet(key, value){ fileFacets[key] = value; render('files'); }
function setFileColSort(col){
  if (fileColSort.col === col) fileColSort.dir = fileColSort.dir === 'asc' ? 'desc' : 'asc';
  else fileColSort = { col, dir: col === 'subtunes' ? 'desc' : 'asc' };
  render('files');
}
function toggleComposerGroup(name){
  if (_expandedComposers.has(name)) _expandedComposers.delete(name);
  else _expandedComposers.add(name);
  render('files');
}

function renderFiles(grid){
  grid.style.gridTemplateColumns = '1fr';
  // Filter every file; keep only composers that still have at least one.
  const groups = [];
  let shownFiles = 0;
  fileGroups().forEach((g) => {
    const filtered = g.files.filter(fileMatchesFilters);
    if (!filtered.length) return;
    g._filtered = filtered;
    shownFiles += filtered.length;
    groups.push(g);
  });
  // Group (composer) order comes from the shared sort dropdown.
  groups.sort((a, b) => {
    if (currentSort === 'composer-desc') return b.composer.localeCompare(a.composer);
    if (currentSort === 'files-desc') return b._filtered.length - a._filtered.length || a.composer.localeCompare(b.composer);
    if (currentSort === 'files-asc') return a._filtered.length - b._filtered.length || a.composer.localeCompare(b.composer);
    return a.composer.localeCompare(b.composer); // composer-asc, default
  });
  document.getElementById('search-count').textContent = `${fmtNum(shownFiles)} shown`;

  const anyNarrowing = currentFilter || fileFacets.source || fileFacets.ident || fileFacets.info || fileFacets.tool;
  const autoExpand = anyNarrowing && groups.length <= AUTO_EXPAND_GROUPS;
  const toolbar = filesToolbar(shownFiles, groups.length);
  if (groups.length === 0) {
    grid.innerHTML = `<div class="fw">${toolbar}${emptyState(allFiles().length ? 'No files match the current find/filters.' : 'No file data cached yet.', allFiles().length ? '' : 'node scripts/fetch-composers.js')}</div>`;
    return;
  }
  const body = groups.map((g) => {
    const open = autoExpand || _expandedComposers.has(g.composer);
    const distinctTools = new Set(g._filtered.map((f) => (f.player ? (resolveTag(f.player)?.title || f.player) : null)).filter(Boolean)).size;
    const esc = g.composer.replace(/'/g, "\\'");
    const head = `<div class="fgrp-h" onclick="toggleComposerGroup('${esc}')">
      <span class="fgrp-caret">${open ? '▾' : '▸'}</span>
      <span class="fgrp-name">${g.composer}</span>
      <span class="fgrp-meta">${fmtNum(g._filtered.length)} file${g._filtered.length === 1 ? '' : 's'} · ${fmtNum(distinctTools)} tool${distinctTools === 1 ? '' : 's'}</span>
      <a class="fgrp-jump" href="#" onclick="event.stopPropagation();jumpToComposer('${esc}');return false;" title="Go to composer card">card ↗</a>
    </div>`;
    return `<div class="fgrp">${head}${open ? `<div class="fgrp-body">${buildFilesTable(g)}</div>` : ''}</div>`;
  }).join('');
  grid.innerHTML = `<div class="fw">${toolbar}${body}</div>`;
}

// Shared horizontal bar-chart renderer — entries is already-sorted
// [label, value][], scaled relative to the largest value in the set (not
// a fixed max), same visual language across every chart that uses it.
function barChart(entries, opts){
  opts = opts || {};
  const color = opts.color || 'var(--cyan)';
  const labelFn = opts.labelFn || ((name) => name);
  // valueFn(n, name) overrides the right-hand display text (e.g. "53% (119)"
  // for a percentage chart) while n still drives the bar's proportional
  // width — used by the coder-rate-by-country chart, which shows a
  // percentage, not a raw count.
  const valueFn = opts.valueFn || ((n) => fmtNum(n));
  const max = Math.max(...entries.map(([, n]) => n), 1);
  return entries.map(([name, n]) => `<div class="bar-row">
    <span class="bar-label">${labelFn(name)}</span>
    <div class="bar-track"><div class="bar-fill" style="width:${(n / max * 100).toFixed(1)}%;background:${color}"></div></div>
    <div class="bar-num">${valueFn(n, name)}</div>
  </div>`).join('');
}

function renderCountries(grid){
  grid.style.gridTemplateColumns = '1fr';
  const composers = window.SID_DATA.composers || [];
  const counts = {};
  composers.forEach(c => {
    const country = c.profile && c.profile.country;
    if (!country) return;
    counts[country] = (counts[country] || 0) + 1;
  });
  let entries = Object.entries(counts).sort((a,b) => b[1]-a[1]);
  if (currentFilter) entries = entries.filter(([name]) => name.toLowerCase().includes(currentFilter));
  document.getElementById('search-count').textContent = `${entries.length} countries`;
  if (entries.length === 0) {
    grid.innerHTML = emptyState('No composer profile data with country info cached yet.', 'node scripts/fetch-composers.js');
    return;
  }
  const bars = barChart(entries, { labelFn: (name) => `${flagFor(name)} ${name}` });
  grid.innerHTML = `<div class="fw" style="padding-top:1.5rem">${bars}</div>`;
}

function stripTags(html){
  return (html || '').replace(/<[^>]*>/g, '').trim();
}

// Shared by the Players tab (inline family badge + detail panel) and the
// Families tab (full list) — one grouping pass, not two.
function computePlayerFamilies(players){
  const byDev = {};
  players.forEach(p => {
    if (p.inferred) return; // no known developer to group by — see deriveSyntheticPlayers()
    const key = stripTags(p.developer) || '(unknown developer)';
    byDev[key] = byDev[key] || { developerHtml: p.developer || '(unknown developer)', titles: [] };
    byDev[key].titles.push(p.title || '(untitled)');
  });
  return byDev;
}

// Flattens every composer's files into one list, tagged with composer
// name/path — computed on demand rather than embedded as a second copy
// of the same ~55,000 records in the page payload (see build-html.js).
let _allFilesCache = null;
function allFiles(){
  if (_allFilesCache) return _allFilesCache;
  const composers = window.SID_DATA.composers || [];
  _allFilesCache = composers.flatMap(c => (c.files || []).map(f => ({ ...f, composer: c.name, composerPath: c.path })));
  return _allFilesCache;
}

// A file's DeepSID link is always `?file=<composer path><filename>` —
// reconstructed here instead of being stored per file (see build-html.js).
function deepsidFileUrl(f){
  if (!f.composerPath || !f.file) return null;
  return `https://deepsid.chordian.net/?file=${f.composerPath.replace(/^\//,'')}${f.file}`;
}

// Reuses matchPlayer() (rather than its own separate loose comparison,
// the previous approach) so a version-forked player's "files using this"
// list agrees with the Files tab's per-row match and the Players tab's
// usage-count badge — all three now resolve through the same logic.
function filesForPlayer(player, files, players){
  return files.filter((f) => f.player && matchPlayer(f.player, players) === player);
}

function renderFamilies(grid){
  grid.style.gridTemplateColumns = '1fr';
  const players = window.SID_DATA.players || [];
  document.getElementById('search-count').textContent = `${players.length} players scanned`;
  if (players.length === 0) {
    grid.innerHTML = emptyState('No player/editor data cached yet.', 'node scripts/fetch-players.js');
    return;
  }

  // Group by developer — DeepSID's `developer` field is itself HTML (often an
  // <a> link to the person's composer page), so the grouping key strips tags
  // but display keeps the original markup, same trust model as the Players tab.
  let families = Object.values(computePlayerFamilies(players)).filter(f => f.titles.length > 1);
  if (currentFilter) {
    families = families.filter(f =>
      stripTags(f.developerHtml).toLowerCase().includes(currentFilter) ||
      f.titles.some(t => t.toLowerCase().includes(currentFilter))
    );
  }
  families.sort((a,b) => b.titles.length - a.titles.length);

  const familyRows = families.map(f => `<div class="gap-item" style="border-left-color:var(--cyan)">
    <div class="gap-type" style="color:var(--cyan)">${f.titles.length} tools by the same developer</div>
    <div>${f.developerHtml} — ${f.titles.join(', ')}</div>
  </div>`).join('');

  // Real derivation links: DeepSID's own `import_from` field, where populated.
  // Free text (e.g. "Soundmonitor + Future Composer v1.0") can name several
  // products at once, sometimes with a specific version and sometimes without
  // (e.g. "GoatTracker instruments") — so this finds every exact (version-
  // intact) substring match first, then separately loose-matches (version-
  // stripped, deduped to one hit per product) anything not already covered,
  // so a multi-product string doesn't lose its unversioned members just
  // because one other member happened to match exactly.
  const links = players.filter(p => p.import_from && p.import_from.trim());
  const linkRows = links.map(p => {
    const raw = p.import_from.toLowerCase();
    const exactMatches = players.filter(other => other.title !== p.title && raw.includes(other.title.toLowerCase()));
    const resolved = normalizePlayerName(p.import_from);
    const seenProduct = new Set(exactMatches.map(o => normalizePlayerName(o.title)));
    const looseMatches = players.filter(other => {
      if (other.title === p.title) return false;
      const norm = normalizePlayerName(other.title);
      if (norm.length < 3 || !resolved.includes(norm) || seenProduct.has(norm)) return false;
      seenProduct.add(norm);
      return true;
    });
    const linkedTitles = [...exactMatches, ...looseMatches];
    const linkedHtml = linkedTitles.map(o => `<span class="tag ok">${o.title}</span>`).join('');
    return `<div class="gap-item" style="border-left-color:var(--amber)">
      <div class="gap-type" style="color:var(--amber)">${p.title}</div>
      <div>imports from: ${p.import_from}${linkedHtml ? `<div class="tags" style="margin-top:.3rem">${linkedHtml}</div>` : ''}</div>
    </div>`;
  }).join('');

  const note = `<div class="sn">
    <strong style="color:var(--text)">On "most players derive from Rob Hubbard":</strong>
    the cached dataset doesn't support that literally — none of the ${players.length}
    player/editor entries mention Hubbard, and only ${links.length} have a
    machine-readable derivation field (<code>import_from</code>) at all; Hubbard's
    own player was a custom per-game routine, not a distributable format later
    tools import from. What the data does show: ${families.length} developers/teams
    built more than one distinct player, and among the real derivation links that
    do exist, GoatTracker's own instrument format is the closest thing to a hub —
    imported by its author's other tools and independently by at least one other.
  </div>`;

  grid.innerHTML = `<div class="fw" style="padding-top:1.5rem">
    ${note}
    <div class="sl">Developers with multiple players (${families.length})</div>
    ${familyRows || '<p style="color:var(--dim);font-size:.8rem">None found.</p>'}
    <div class="sl">Known import/derivation links (${links.length})</div>
    ${linkRows || '<p style="color:var(--dim);font-size:.8rem">None found — import_from is unpopulated for every cached player.</p>'}
  </div>`;
}

const GROUPS_TAB_CAP = 300;

// CSDb's group membership (composer.csdb.groups, already summarized
// server-side by summarizeCsdb()) is per-composer — nothing aggregates it
// across the whole dataset yet, even though it's the richest untapped
// insight CSDb enrichment produced: 737 groups have 2+ SID composers as
// members, once you can see across all 1,609 CSDb-enriched composers at
// once instead of one card at a time.
function computeGroupMembership(composers){
  const byGroup = new Map();
  composers.forEach((c) => {
    (c.csdb && c.csdb.groups || []).forEach((g) => {
      if (!g.name) return;
      if (!byGroup.has(g.name)) byGroup.set(g.name, []);
      byGroup.get(g.name).push(c.name);
    });
  });
  return byGroup;
}

function renderGroups(grid){
  grid.style.gridTemplateColumns = '1fr';
  const composers = window.SID_DATA.composers || [];
  const byGroup = computeGroupMembership(composers);

  // A group with exactly one cached SID composer isn't really an
  // "insight" — same threshold the Player Families tab already uses for
  // developers with only one tool.
  let entries = [...byGroup.entries()].filter(([, members]) => members.length > 1);
  if (currentFilter) {
    entries = entries.filter(([name, members]) =>
      name.toLowerCase().includes(currentFilter) || members.some((m) => m.toLowerCase().includes(currentFilter))
    );
  }
  entries.sort((a, b) => b[1].length - a[1].length);
  document.getElementById('search-count').textContent = `${entries.length} groups with 2+ cached composers`;

  if (entries.length === 0) {
    grid.innerHTML = emptyState('No CSDb group data cached yet.', 'node scripts/fetch-csdb.js');
    return;
  }

  const rows = entries.slice(0, GROUPS_TAB_CAP).map(([name, members]) => {
    const shown = members.slice(0, 30);
    const memberLinks = shown
      .map((m) => `<a href="#" onclick="jumpToComposer('${m.replace(/'/g, "\\'")}');return false;" style="color:var(--cyan);text-decoration:none">${m}</a>`)
      .join(', ');
    const more = members.length > shown.length ? ` <span style="color:var(--dim)">+${members.length - shown.length} more</span>` : '';
    return `<div class="gap-item" style="border-left-color:var(--cyan)">
      <div class="gap-type" style="color:var(--cyan)">${name} — ${members.length} composer${members.length === 1 ? '' : 's'}</div>
      <div style="font-size:.78rem">${memberLinks}${more}</div>
    </div>`;
  }).join('');
  const capNote = entries.length > GROUPS_TAB_CAP
    ? `<p style="color:var(--dim);font-size:.75rem;margin-top:.5rem">+${entries.length - GROUPS_TAB_CAP} more groups — refine your search to narrow this down.</p>`
    : '';

  grid.innerHTML = `<div class="fw" style="padding-top:1.5rem">${rows}${capNote}</div>`;
}

const INSIGHTS_ROLE_CAP = 15;
const INSIGHTS_PROLIFIC_CAP = 20;
const INSIGHTS_MOBILITY_CAP = 15;

// "unreleased" is excluded — a known, isolated composer-identity quirk
// from the DeepSID database import: /MUSICIANS/L/Link/unreleased/ is a
// subfolder of composer "Link"'s own directory, not a separate person,
// but the dump's folder-depth-based identity derivation treated it as
// one anyway (see TODO.md). Confirmed isolated (1 of 1,902) rather than
// a systemic issue, so this exclusion — not a broader identity fix — is
// the right scope for keeping this specific chart honest.
const INSIGHTS_EXCLUDED_COMPOSERS = new Set(['unreleased']);

function computeActivityByYear(composers){
  const counts = {};
  composers.forEach((c) => {
    const active = c.profile && c.profile.active;
    if (!active) return;
    const year = active.slice(0, 4);
    if (!/^\d{4}$/.test(year) || year === '0000') return;
    counts[year] = (counts[year] || 0) + 1;
  });
  return counts;
}

function computeRoleCounts(composers){
  const counts = {};
  composers.forEach((c) => {
    (c.csdb && c.csdb.roles || []).forEach((r) => { counts[r] = (counts[r] || 0) + 1; });
  });
  return counts;
}

function computeMostProlific(composers, limit){
  return composers
    .filter((c) => !INSIGHTS_EXCLUDED_COMPOSERS.has((c.name || '').toLowerCase()))
    .map((c) => [c.name, (c.files || []).length])
    .filter(([, n]) => n > 0)
    .sort((a, b) => b[1] - a[1])
    .slice(0, limit);
}

// How many distinct groups each CSDb-enriched composer has belonged to —
// a proxy for "scene mobility": moving between crews over a career versus
// staying with one. Reuses composer.csdb.groups, already in the payload.
function computeGroupMobility(composers, limit){
  return composers
    .map((c) => [c.name, ((c.csdb && c.csdb.groups) || []).length])
    .filter(([, n]) => n > 0)
    .sort((a, b) => b[1] - a[1])
    .slice(0, limit);
}

// Approximates "which tool dominated which era" by tagging every one of a
// composer's files with their DeepSID `active` year, then bucketing into
// decades — an approximation, not a per-file date (files don't carry
// individual creation dates), so a composer with a decades-long career
// has all their files counted under one bucket. Raw player tag strings
// (e.g. "GoatTracker_V2.x") are used as-is, not resolved through
// matchPlayer() — this is a coarse "what showed up" scan, not a precise
// per-version count like the Players tab's usage badges.
const INSIGHTS_ERAS = [
  ['1980s', 1980, 1989], ['1990s', 1990, 1999], ['2000s', 2000, 2009],
  ['2010s', 2010, 2019], ['2020s', 2020, 2029],
];
const INSIGHTS_ERA_TOOL_CAP = 5;
function computeEraToolDominance(composers){
  const byEra = {};
  INSIGHTS_ERAS.forEach(([label]) => { byEra[label] = {}; });
  composers.forEach((c) => {
    const active = c.profile && c.profile.active;
    const year = active && parseInt(active.slice(0, 4), 10);
    if (!year) return;
    const era = INSIGHTS_ERAS.find(([, start, end]) => year >= start && year <= end);
    if (!era) return;
    (c.files || []).forEach((f) => {
      if (!f.player) return;
      byEra[era[0]][f.player] = (byEra[era[0]][f.player] || 0) + 1;
    });
  });
  return byEra;
}

// Coder-rate by country — restricted to countries with a minimum sample
// size so a country with 2 CSDb-enriched composers, one of whom happens to
// code, doesn't show up as "50% coders" next to real 100+-composer samples.
function computeCoderRateByCountry(composers, minSample){
  const totals = {};
  const coders = {};
  composers.forEach((c) => {
    const country = c.profile && c.profile.country;
    const roles = (c.csdb && c.csdb.roles) || [];
    if (!country || !roles.length) return;
    totals[country] = (totals[country] || 0) + 1;
    if (roles.includes('Coder')) coders[country] = (coders[country] || 0) + 1;
  });
  const entries = Object.keys(totals)
    .filter((c) => totals[c] >= minSample)
    .map((c) => [c, Math.round((100 * (coders[c] || 0)) / totals[c])]);
  entries.sort((a, b) => b[1] - a[1]);
  return { entries, totals };
}

// Files-per-composer average by country — a different cut than the
// Countries tab (which counts composers, not output): a country with
// fewer composers can still out-produce a bigger one on a per-person
// basis. Same minimum-sample-size gating as the coder-rate chart.
function computeAvgFilesByCountry(composers, minSample){
  const fileTotals = {};
  const composerTotals = {};
  composers.forEach((c) => {
    const country = c.profile && c.profile.country;
    if (!country) return;
    composerTotals[country] = (composerTotals[country] || 0) + 1;
    fileTotals[country] = (fileTotals[country] || 0) + ((c.files || []).length);
  });
  const entries = Object.keys(composerTotals)
    .filter((c) => composerTotals[c] >= minSample)
    .map((c) => [c, Math.round((fileTotals[c] / composerTotals[c]) * 10) / 10]);
  entries.sort((a, b) => b[1] - a[1]);
  return { entries, composerTotals };
}

function renderInsights(grid){
  grid.style.gridTemplateColumns = '1fr';
  const composers = window.SID_DATA.composers || [];
  document.getElementById('search-count').textContent = `${composers.length} composers analyzed`;
  if (composers.length === 0) {
    grid.innerHTML = emptyState('No composer data cached yet.', 'node scripts/fetch-composers.js');
    return;
  }

  // Chronological, not ranked by size — this is a timeline, so the point
  // is the shape over time (recent years rival the mid-1980s), not a
  // leaderboard.
  const yearCounts = computeActivityByYear(composers);
  const yearEntries = Object.entries(yearCounts).sort((a, b) => a[0].localeCompare(b[0]));
  const recentTotal = yearEntries.filter(([y]) => Number(y) >= 2023).reduce((s, [, n]) => s + n, 0);
  const eightiesTotal = yearEntries.filter(([y]) => Number(y) >= 1983 && Number(y) <= 1989).reduce((s, [, n]) => s + n, 0);

  const roleCounts = computeRoleCounts(composers);
  const roleEntries = Object.entries(roleCounts).sort((a, b) => b[1] - a[1]);
  const roleShown = roleEntries.slice(0, INSIGHTS_ROLE_CAP);
  const musicianTotal = roleCounts.Musician || 0;
  const multiRoleTotal = composers.filter((c) => {
    const roles = (c.csdb && c.csdb.roles) || [];
    return roles.some((r) => r !== 'Musician');
  }).length;

  const prolific = computeMostProlific(composers, INSIGHTS_PROLIFIC_CAP);
  const allFileCounts = computeMostProlific(composers, Infinity);
  const top50Total = allFileCounts.slice(0, 50).reduce((s, [, n]) => s + n, 0);
  const grandTotal = allFileCounts.reduce((s, [, n]) => s + n, 0);
  const top50Share = grandTotal ? Math.round((100 * top50Total) / grandTotal) : 0;

  const mobility = computeGroupMobility(composers, INSIGHTS_MOBILITY_CAP);
  const mobileTotal = composers.filter((c) => ((c.csdb && c.csdb.groups) || []).length >= 3).length;
  const csdbTotal = composers.filter((c) => c.csdb).length;

  const stil = window.SID_DATA.stilCoverStats || { total: 0, covers: 0 };
  const coverPct = stil.total ? Math.round((100 * stil.covers) / stil.total) : 0;
  const originals = stil.total - stil.covers;

  const subtunes = window.SID_DATA.subtuneStats || { total: 0, multi: 0, max: null };
  const subtunePct = subtunes.total ? ((100 * subtunes.multi) / subtunes.total).toFixed(1) : 0;

  const eraDominance = computeEraToolDominance(composers);
  const eraSections = INSIGHTS_ERAS.map(([label]) => {
    const entries = Object.entries(eraDominance[label]).sort((a, b) => b[1] - a[1]).slice(0, INSIGHTS_ERA_TOOL_CAP);
    if (!entries.length) return '';
    return `<div style="margin-bottom:1rem">
      <div style="font-family:'Share Tech Mono',monospace;font-size:.68rem;color:var(--text);margin-bottom:.3rem">${label}</div>
      ${barChart(entries, { color: 'var(--cyan)' })}
    </div>`;
  }).join('');

  const coderRate = computeCoderRateByCountry(composers, 20);
  const avgFiles = computeAvgFilesByCountry(composers, 15);

  grid.innerHTML = `<div class="fw" style="padding-top:1.5rem">
    <div class="sl">Composer activity by year (${yearEntries.length} years, ${yearEntries[0]?.[0] || '?'}–${yearEntries[yearEntries.length - 1]?.[0] || '?'})</div>
    <div class="sn" style="margin-bottom:.75rem">This isn't a purely historical archive — ${fmtNum(recentTotal)} composers were active
      2023–2026 alone, versus ${fmtNum(eightiesTotal)} across the entire 1983–1989 era the C64 originally shipped in.</div>
    ${barChart(yearEntries, { color: 'var(--amber)' })}

    <div class="sl">Scene roles credited on CSDb (top ${roleShown.length} of ${roleEntries.length})</div>
    <div class="sn" style="margin-bottom:.75rem">${fmtNum(multiRoleTotal)} of ${fmtNum(musicianTotal)} CSDb-credited composers
      are credited for more than just music — coding, graphics, swapping, and cracking all show up.</div>
    ${barChart(roleShown, { color: 'var(--green)' })}

    <div class="sl">Most prolific composers, by cached SID file count (top ${prolific.length})</div>
    <div class="sn" style="margin-bottom:.75rem">The top 50 composers (${allFileCounts.length ? (50 / allFileCounts.length * 100).toFixed(1) : 0}% of everyone with a
      file) made ${fmtNum(top50Total)} of ${fmtNum(grandTotal)} files — ${top50Share}% of the whole collection.
      Median composer has far fewer: a long tail, not an even spread.</div>
    ${barChart(prolific, { color: 'var(--cyan)', labelFn: (name) => `<a href="#" onclick="jumpToComposer('${name.replace(/'/g, "\\'")}');return false;" style="color:inherit;text-decoration:none">${name}</a>` })}

    <div class="sl">Covers vs. originals, where documented</div>
    <div class="sn" style="margin-bottom:.75rem">HVSC's STIL.txt tags a tune with "[from X]" when it's an adaptation of
      existing music (movie/TV themes, pop songs, other games) — DeepSID's own data doesn't track this at all.
      Of the ${fmtNum(stil.total)} files with STIL documentation (about ${allFiles().length ? Math.round(100 * stil.total / allFiles().length) : 0}%
      of the full collection — STIL doesn't document everything), ${coverPct}% are explicit covers/adaptations, not
      original compositions. ${subtunes.total ? `And ${subtunePct}% of all ${fmtNum(subtunes.total)} files have 2+ subtunes
      (medleys) — the record is ${subtunes.max ? `<a href="#" onclick="jumpToComposer('${subtunes.max.composer.replace(/'/g, "\\'")}');return false;" style="color:inherit">${subtunes.max.composer}</a>'s
      "${subtunes.max.file}" at ${subtunes.max.subtunes} subtunes` : 'unknown'}, almost certainly a procedural-generation
      experiment rather than a composed piece.` : ''}</div>
    ${barChart([['Covers / adaptations', stil.covers], ['Original compositions', originals]], { color: 'var(--red)' })}

    <div class="sl">Which tool dominated which era</div>
    <div class="sn" style="margin-bottom:.75rem">Approximate — each file is tagged with its composer's overall DeepSID
      "active" year, not an individual file date (files don't carry one), so a decades-spanning career lands in one
      bucket. Still shows a clear handoff: SoundMonitor/MusicMaster led the 1980s, Music Assembler and the DMC family
      took over the 1990s–2000s, and GoatTracker v2.x has dominated since the 2010s — exploding in the 2020s to more
      files than any other era's leader.</div>
    ${eraSections}

    <div class="sl">Coder rate by country (min. 20 CSDb-credited composers)</div>
    <div class="sn" style="margin-bottom:.75rem">Share of each country's CSDb-credited composers who are also
      credited as a coder, not just a musician — restricted to countries with a large enough sample that one or two
      people don't swing the percentage.</div>
    ${barChart(coderRate.entries, {
      color: 'var(--green)',
      labelFn: (name) => `${flagFor(name)} ${name}`,
      valueFn: (pct, name) => `${pct}% <span style="color:var(--dim)">(${fmtNum(coderRate.totals[name])})</span>`,
    })}

    <div class="sl">Most group-affiliated composers (top ${mobility.length})</div>
    <div class="sn" style="margin-bottom:.75rem">${fmtNum(mobileTotal)} of ${fmtNum(csdbTotal)} CSDb-enriched composers belonged to
      3 or more different groups over their career — the scene was highly mobile, not siloed into one crew for life.</div>
    ${barChart(mobility, { color: 'var(--amber)', labelFn: (name) => `<a href="#" onclick="jumpToComposer('${name.replace(/'/g, "\\'")}');return false;" style="color:inherit;text-decoration:none">${name}</a>` })}

    <div class="sl">Files per composer, by country (min. 15 composers)</div>
    <div class="sn" style="margin-bottom:.75rem">A different cut than the Countries tab, which counts composers, not
      output — the biggest countries by headcount aren't necessarily the most prolific per person.</div>
    ${barChart(avgFiles.entries, {
      color: 'var(--red)',
      labelFn: (name) => `${flagFor(name)} ${name}`,
      valueFn: (avg, name) => `${avg} <span style="color:var(--dim)">(${fmtNum(avgFiles.composerTotals[name])} composers)</span>`,
    })}
  </div>`;
}

function renderGaps(grid){
  grid.style.gridTemplateColumns = '1fr';
  let list = window.SID_DATA.gaps || [];
  if (currentFilter) list = list.filter(g => JSON.stringify(g).toLowerCase().includes(currentFilter));
  list = [...list].sort((a, b) => {
    if (currentSort === 'composer-asc') return (a.composer || a.title || '').localeCompare(b.composer || b.title || '');
    return a.type.localeCompare(b.type); // type-asc, and the default
  });
  document.getElementById('search-count').textContent = `${list.length} shown`;
  if (list.length === 0) {
    grid.innerHTML = emptyState('No gaps report cached yet.', 'node scripts/find-gaps.js');
    return;
  }
  function suggestionLine(s){
    if (!s) return '';
    if (s.site) return `<div class="sn" style="margin:.5rem 0 0">💡 Suggested fix: <a href="${s.site}" target="_blank">${s.site}</a> <span style="color:var(--dim)">(via ${s.source})</span></div>`;
    const bits = [s.realName && `real name: ${s.realName}`, s.group && `group: ${s.group}`, s.country && `country: ${s.country}`].filter(Boolean).join(' · ');
    return `<div class="sn" style="margin:.5rem 0 0">💡 Suggested fix: ${bits} <span style="color:var(--dim)">(via ${s.source})</span></div>`;
  }
  const items = list.slice(0, 300).map(g => `<div class="gap-item">
    <div class="gap-type">${g.type}</div>
    <div>${g.composer || g.title || ''} ${g.file ? '— ' + g.file : ''} ${g.detail ? '— ' + g.detail : ''}</div>
    ${g.missingFields ? `<div class="cnote">missing: ${g.missingFields.join(', ')}</div>` : ''}
    ${suggestionLine(g.suggestion)}
  </div>`).join('');
  const more = list.length > 300 ? `<p style="color:var(--dim);font-size:.75rem;margin-top:.5rem">+${list.length-300} more — see docs/GAPS_REPORT.md</p>` : '';
  grid.innerHTML = `<div class="fw" style="padding-top:1.5rem">${items}${more}</div>`;
}

function jumpToComposer(name){
  if (currentTab !== 'composers' || currentFilter) {
    document.getElementById('search-input').value = '';
    currentFilter = '';
    render('composers');
  }
  requestAnimationFrame(() => {
    const el = document.querySelector(`.card[data-name="${CSS.escape(name.toLowerCase())}"]`);
    if (!el) return;
    el.scrollIntoView({behavior:'smooth', block:'center'});
    el.classList.add('hl');
    setTimeout(() => el.classList.remove('hl'), 1700);
  });
}

function randomComposer(){
  const list = window.SID_DATA.composers || [];
  if (!list.length) return;
  const pick = list[Math.floor(Math.random() * list.length)];
  jumpToComposer(pick.name);
}

// Extend the curated players list with synthetic entries derived from raw
// file data (see deriveSyntheticPlayers()) — done once here, before
// anything else reads window.SID_DATA.players, so every existing consumer
// (Files tab matching, usage counts, the Players tab itself, Insights)
// picks these up automatically instead of needing separate wiring.
window.SID_DATA.players = (window.SID_DATA.players || []).concat(
  deriveSyntheticPlayers(allFiles(), window.SID_DATA.players || [])
);

renderPills();
render('composers');
</script>
</body>
</html>
